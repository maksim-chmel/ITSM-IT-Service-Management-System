@model IEnumerable<ITSM.ViewModels.Manage.UserWithRolesViewModel>

@{
    ViewData["Title"] = "User Management";
    var search = Context.Request.Query["search"];
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Administration</div>
        <h1 class="section-title">Keep accounts, roles, and category ownership under control.</h1>
        <p class="section-copy">This screen centralizes user search, role assignment, profile edits, and category targeting.</p>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Search and manage all active users in the environment.</p>
            </div>
        </div>

        <form method="get" class="compact-search mb-4">
            <input type="text" name="search" class="form-control" placeholder="Search by name or email" value="@search" />
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        </form>

        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-dark text-white">
                    <tr>
                        <th>User ID</th>
                        <th>User Name</th>
                        <th>Email</th>
                        <th>Phone Number</th>
                        <th>Role</th>
                        <th>Specification</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="table-light">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td class="text-truncate truncate-200" title="@user.UserName">@user.UserName</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>
                                <div class="chip-list">
                                    @foreach (var role in user.Roles)
                                    {
                                        <span class="chip">@role</span>
                                    }
                                </div>
                            </td>
                            <td>
                                @if (user.AssignedCategories.Any())
                                {
                                    <div class="chip-list">
                                        @foreach (var category in user.AssignedCategories)
                                        {
                                            <span class="chip">@category</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">No categories assigned</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="userActionsDropdown-@user.Id"
                                            data-bs-toggle="dropdown" aria-expanded="false">
                                        Actions
                                    </button>
                                    <ul class="dropdown-menu" aria-labelledby="userActionsDropdown-@user.Id">
                                        <li>
                                            <a class="dropdown-item" asp-controller="UserManagement" asp-action="EditUser"
                                               asp-route-id="@user.Id">
                                                Edit Profile
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="UserRoles" asp-action="ManageRoles"
                                               asp-route-userId="@user.Id">
                                                Manage Roles
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="UserManagement" asp-action="AssignCategoryToUser"
                                               asp-route-userId="@user.Id">
                                                Category
                                            </a>
                                        </li>
                                        <li>
                                            <button type="button" class="dropdown-item text-danger"
                                                    data-bs-toggle="modal" data-bs-target="#archiveUserModal"
                                                    data-user-id="@user.Id" data-user-name="@user.UserName">
                                                Archive User
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<form id="archiveUserForm" asp-controller="UserManagement" asp-action="DeleteUser" method="post">
    <input type="hidden" id="archiveUserId" name="id" />
</form>

<div class="modal fade" id="archiveUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Archive User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Archive <strong id="archiveUserName"></strong>? Their account will be locked and they will be signed out immediately.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="archiveUserConfirm">Archive</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("archiveUserModal").addEventListener("show.bs.modal", function (e) {
            const btn = e.relatedTarget;
            document.getElementById("archiveUserId").value = btn.dataset.userId;
            document.getElementById("archiveUserName").textContent = btn.dataset.userName;
        });
        document.getElementById("archiveUserConfirm").addEventListener("click", function () {
            document.getElementById("archiveUserForm").submit();
        });
    </script>
}
