@{
    ViewData["Title"] = "Archive";
}

<h2 class="text-center my-4 display-5 text-secondary">Deleted Items Archive</h2>

<div class="d-flex justify-content-center flex-wrap gap-4">

    <a asp-controller="Archive" asp-action="DeletedArticles" class="btn btn-outline-primary btn-lg shadow-sm px-4 py-2">
        <i class="bi bi-journal-text me-2"></i> Articles Archive
    </a>

    <a asp-controller="Archive" asp-action="DeletedTickets" class="btn btn-outline-success btn-lg shadow-sm px-4 py-2">
        <i class="bi bi-ticket-perforated me-2"></i> Tickets Archive
    </a>

    <a asp-controller="Archive" asp-action="DeletedCategories" class="btn btn-outline-secondary btn-lg shadow-sm px-4 py-2">
        <i class="bi bi-tags me-2"></i> Categories Archive
    </a>

    <a asp-controller="Archive" asp-action="DeletedUsers" class="btn btn-outline-danger btn-lg shadow-sm px-4 py-2">
        <i class="bi bi-person-x me-2"></i> Users Archive
    </a>
</div>