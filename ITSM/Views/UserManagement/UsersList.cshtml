@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<ITSM.ViewModels.UserWithRolesViewModel>
@{
    ViewData["Title"] = "User Management";
}
<h2 class="text-center mb-4">@ViewData["Title"]</h2>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover table-bordered align-middle text-center">
        <thead class="table-dark text-white">
            <tr>
                <th>User ID</th>
                <th>User Name</th>
                <th>Email</th>
                <th>Phone Number</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody class="table-light">
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td class="text-truncate" style="max-width: 200px;" title="@user.UserName">@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@user.PhoneNumber</td>
                    <td>@user.Roles</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="userActionsDropdown"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                Actions
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="userActionsDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="UserManagement" asp-action="EditUser"
                                       asp-route-id="@user.Id">
                                        EditProfile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="UserRoles" asp-action="ManageRoles"
                                       asp-route-userId="@user.Id">
                                        Manage Roles
                                    </a>
                                </li>
                                <li>
                                    <form asp-controller="UserManagement" asp-action="DeleteUser"
                                          asp-route-id="@user.Id" method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <button type="submit" class="dropdown-item text-danger">Delete</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
