@using ITSM.Enums
@using System.Security.Claims
@model ITSM.ViewModels.Manage.TicketDetailsViewModel

@{
    // Helper to determine badge color based on status
    Func<Status, string> getBadgeClass = status =>
    {
        return status switch
        {
            Status.New => "bg-primary",
            Status.Open => "bg-info",
            Status.Progress => "bg-warning text-dark",
            Status.OnHold => "bg-secondary",
            Status.Reopened => "bg-danger",
            Status.Resolved => "bg-success",
            Status.Canceled => "bg-dark",
            _ => "bg-light text-dark"
        };
    };
    var statusBadgeClass = getBadgeClass(Model.Ticket.Status);
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="d-grid gap-4">
    <div class="page-actions d-flex justify-content-between">
        <a asp-controller="TechnicianTicket" asp-action="ToDoTicketsList" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Queue
        </a>
        
        <!-- Action Buttons Group -->
        <div class="d-flex gap-2">
            @if (Model.Ticket.Status == Status.Progress)
            {
                <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#placeOnHoldModal">
                    <i class="bi bi-pause-circle"></i> Place On Hold
                </button>
                <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#resolveTicketModal">
                    <i class="bi bi-check-circle"></i> Mark as Resolved
                </button>
            }
            
            @if (Model.Ticket.Status == Status.OnHold)
            {
                <form method="post" asp-controller="TechnicianTicket" asp-action="ResumeProgress" asp-route-id="@Model.Ticket.Id">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-play-circle"></i> Resume Progress
                    </button>
                </form>
            }

            @if (Model.Ticket.Status == Status.Resolved && (Model.Ticket.AuthorId == currentUserId || User.IsInRole("Admin")))
            {
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#reopenTicketModal">
                    <i class="bi bi-arrow-clockwise"></i> Re-open Ticket
                </button>
            }

            @if (Model.Ticket.AssignedUserId != null && (User.IsInRole("Admin") || User.IsInRole("Coordinator")))
            {
                <form method="post" asp-controller="TechnicianTicket" asp-action="UnassignTicket" asp-route-id="@Model.Ticket.Id">
                    <button type="submit" class="btn btn-outline-warning">
                        <i class="bi bi-person-x"></i> Unassign
                    </button>
                </form>
            }
        </div>
    </div>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>Ticket #@Model.Ticket.Id: @Model.Ticket.Title</h2>
                <p class="text-muted mb-0">Technician detail view for execution notes and resolution actions.</p>
            </div>
            <span class="badge @statusBadgeClass fs-6">@Model.Ticket.Status</span>
        </div>
        <div class="info-grid">
            <div class="info-card"><dl><dt>Author</dt><dd>@Model.Ticket.Author?.UserName</dd></dl></div>
            <div class="info-card"><dl><dt>Created At</dt><dd>@Model.Ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd></dl></div>
            <div class="info-card"><dl><dt>Assigned To</dt><dd>@(Model.Ticket.AssignedUser?.UserName ?? "Unassigned")</dd></dl></div>
            <div class="info-card"><dl><dt>Description</dt><dd>@Model.Ticket.Description</dd></dl></div>
            @if (Model.Ticket.Status == Status.Resolved)
            {
                <div class="info-card"><dl><dt>Fix Description</dt><dd>@Model.Ticket.FixDescription</dd></dl></div>
            }
             @if (Model.Ticket.Status == Status.Canceled)
            {
                <div class="info-card"><dl><dt>Cancel Reason</dt><dd>@Model.Ticket.CancelReason</dd></dl></div>
            }
        </div>
    </section>

    <div class="row g-4">
        <div class="col-lg-8">
            <section class="surface-card h-100">
                <div class="page-header">
                    <div>
                        <h3>Operational Log & Notes</h3>
                        <p class="text-muted mb-0">Chronological history of all actions and status changes.</p>
                    </div>
                    @if (Model.Ticket.Status == Status.Progress || Model.Ticket.Status == Status.OnHold)
                    {
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                            <i class="bi bi-plus-circle"></i> Add Log Entry
                        </button>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Note</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var note in Model.TicketHistory.OrderByDescending(h => h.CreatedAt))
                        {
                            <tr>
                                <td>@note.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@note.AdminComment</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
        <div class="col-lg-4">
            <section class="surface-card h-100">
                <h4>Internal Discussions</h4>
                <p class="text-muted small">Coordinate with other team members.</p>
                @if (Model.Discussions.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var discussion in Model.Discussions)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <a asp-controller="Discussion" asp-action="ViewDiscussion" asp-route-id="@discussion.Id">
                                    @discussion.Title
                                </a>
                                <span class="badge @getBadgeClass(discussion.Status)">@discussion.Status</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted fst-italic small">No discussions yet.</p>
                }
                <div class="mt-3">
                    <a asp-controller="Discussion" asp-action="CreateDiscussion" asp-route-ticketId="@Model.Ticket.Id" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-plus-circle"></i> Start Discussion
                    </a>
                </div>
            </section>
        </div>
    </div>
</div>

<!-- Modals -->
<div class="modal fade" id="addNoteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-controller="TechnicianTicket" asp-action="AddNewCommentToTicket">
                <div class="modal-header">
                    <h5 class="modal-title">Add Log Entry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="ticketId" value="@Model.Ticket.Id"/>
                    <textarea class="form-control" name="adminComment" rows="3" placeholder="e.g., 'Called the user, waiting for feedback.'" required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Entry</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="resolveTicketModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-controller="TechnicianTicket" asp-action="ResolveTicket">
                <div class="modal-header">
                    <h5 class="modal-title">Resolution Description</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" value="@Model.Ticket.Id"/>
                    <div class="mb-3">
                        <label class="form-label">Solution</label>
                        <textarea class="form-control" name="solution" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Link to Knowledge Base Article (Optional)</label>
                        <select name="knowledgeBaseArticleId" class="form-select">
                            <option value="">None</option>
                            @foreach (var article in Model.AvailableArticles)
                            {
                                <option value="@article.Value">@article.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="placeOnHoldModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-controller="TechnicianTicket" asp-action="PlaceOnHold" asp-route-id="@Model.Ticket.Id">
                <div class="modal-header">
                    <h5 class="modal-title">Place Ticket On Hold</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason</label>
                    <textarea class="form-control" name="reason" placeholder="e.g., 'Awaiting response from user.'" required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="reopenTicketModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-controller="TechnicianTicket" asp-action="ReopenTicket" asp-route-id="@Model.Ticket.Id">
                <div class="modal-header">
                    <h5 class="modal-title">Re-open Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Reason</label>
                    <textarea class="form-control" name="reason" placeholder="e.g., 'The issue is still occurring.'" required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Re-open</button>
                </div>
            </form>
        </div>
    </div>
</div>
