@model ITSM.ViewModels.Create.TicketCreateViewModel

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">New Request</div>
        <h1 class="section-title">Create a support ticket with enough context to route it correctly.</h1>
        <p class="section-copy">
            Choose the right category first, then describe the issue clearly. Better classification means faster assignment and fewer clarification loops.
        </p>
    </section>

    <div class="surface-card surface-card--narrow">
        <div class="form-floating mb-4">
            <select class="form-select" id="categorySelect">
                <option value="">Select Category</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Value" selected="@(cat.Value == Model.CategoryId.ToString() ? "selected" : null)">@cat.Text</option>
                }
            </select>
            <label>Category</label>
        </div>

        <form asp-action="CreateTicket" method="post">
            <input type="hidden" asp-for="CategoryId" id="CategoryId"/>
            <div class="form-floating mb-4">
                <select asp-for="SubCategoryId" class="form-select" id="SubCategoryId">
                    @if (Model.CategoryId == 0)
                    {
                        <option value="">Select a category first</option>
                    }
                    else
                    {
                        <option value="">No subcategory (optional)</option>
                        @foreach (var sub in Model.SubCategories)
                        {
                            <option value="@sub.Value">@sub.Text</option>
                        }
                    }
                </select>
                <label asp-for="SubCategoryId">Subcategory (Optional)</label>
                <span class="text-danger" asp-validation-for="SubCategoryId"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Title" class="form-control" placeholder="Title"/>
                <label asp-for="Title">Title</label>
                <span class="text-danger" asp-validation-for="Title"></span>
            </div>

            <div class="form-floating mb-4">
                <textarea asp-for="Description" class="form-control textarea-lg" placeholder="Description"></textarea>
                <label asp-for="Description">Description</label>
                <span class="text-danger" asp-validation-for="Description"></span>
            </div>
            <div class="d-flex flex-wrap gap-3">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-patch-plus"></i> Submit Ticket
                </button>
                <span class="text-muted align-self-center">Be specific about symptoms, impact, and what you already tried.</span>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const categorySelect = document.getElementById("categorySelect");
    const subCategorySelect = document.getElementById("SubCategoryId");
    const hiddenCategoryId = document.getElementById("CategoryId");

    // Sync hidden field with current category (handles server-side pre-selection)
    if (categorySelect.value) {
        hiddenCategoryId.value = categorySelect.value;
    } else {
        subCategorySelect.disabled = true;
    }

    categorySelect.addEventListener("change", async function () {
        const categoryId = this.value;
        hiddenCategoryId.value = categoryId || "0";

        if (!categoryId) {
            subCategorySelect.innerHTML = '<option value="">Select a category first</option>';
            subCategorySelect.disabled = true;
            return;
        }

        subCategorySelect.innerHTML = '<option value="">Loading...</option>';
        subCategorySelect.disabled = true;

        try {
            const response = await fetch(`/UserTicket/SubCategories?categoryId=${encodeURIComponent(categoryId)}`);
            const data = await response.json();

            subCategorySelect.innerHTML = '<option value="">No subcategory (optional)</option>';
            data.forEach(function (s) {
                const opt = document.createElement("option");
                opt.value = s.value;
                opt.textContent = s.text;
                subCategorySelect.appendChild(opt);
            });
            subCategorySelect.disabled = false;
        } catch {
            subCategorySelect.innerHTML = '<option value="">Error loading — try again</option>';
            subCategorySelect.disabled = false;
        }
    });

    // Inline validation feedback
    document.querySelectorAll(".form-control").forEach(function (input) {
        input.addEventListener("input", function () {
            this.classList.toggle("is-invalid", !this.checkValidity());
            this.classList.toggle("is-valid", this.checkValidity() && this.value.length > 0);
        });
    });
});
</script>
