@model ITSM.Models.KnowledgeBaseArticle

<div class="article-container">
    <h1 class="article-title">@Model.Article</h1>

    <div class="article-meta">
        <p><strong>Category:</strong> @Model.Category?.Name</p>
        <p><strong>Author:</strong> @Model.Author?.UserName</p>
        <p><strong>Created:</strong> @Model.CreatedAt.ToShortDateString()</p>
    </div>

    <hr class="divider" />

    <div class="article-content">
        @Html.Raw(Model.Content)
    </div>
</div>

<style>
    .article-container {
        max-width: 800px;
        margin: 50px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        text-align: center;
    }

    .article-title {
        font-size: 2.5rem;
        margin-bottom: 20px;
        color: #2d9cdb;
    }

    .article-meta {
        font-size: 1rem;
        color: #777;
        margin-bottom: 20px;
    }

    .article-meta p {
        margin: 5px 0;
    }

    .divider {
        margin: 30px auto;
        width: 80%;
        border: none;
        border-top: 2px solid #f0f0f0;
    }

    .article-content {
        text-align: left;
        font-size: 1.1rem;
        line-height: 1.7;
        color: #333;
    }

    .article-content p {
        margin-bottom: 1rem;
    }
</style>