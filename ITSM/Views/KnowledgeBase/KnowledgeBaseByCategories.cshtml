@model List<ITSM.Models.TicketCategory>

@{
    ViewData["Title"] = "Knowledge Base - Articles";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Knowledge Base</div>
        <h1 class="section-title">Browse articles by support category.</h1>
        <p class="section-copy">Expand a category to see available articles and jump directly into the detailed write-up.</p>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>Knowledge Base</h2>
                <p class="text-muted mb-0">Search categories and open article collections without leaving the page.</p>
            </div>
        </div>

        <div class="filter-container">
            <input type="text" id="categoryFilter" placeholder="Search by category..." onkeyup="filterCategories()" class="form-control mb-3" />
        </div>

        <div id="category-container" class="stack-grid">
            @foreach (var group in Model.GroupBy(c => c.Name[0].ToString().ToUpper()))
            {
                <section class="surface-card">
                    <h3 class="mb-3">@group.Key</h3>
                    <div class="stack-grid">
                        @foreach (var category in group)
                        {
                            <div class="info-card category-card">
                                <div class="d-flex justify-content-between align-items-center gap-3 clickable-row" onclick="toggleCategory('@category.Name')">
                                    <h4 class="mb-0">@category.Name</h4>
                                    <span class="toggle-icon">&#x25B6;</span>
                                </div>
                                <div class="mt-3 is-hidden" id="category-body-@category.Name">
                                    @if (category.Articles != null && category.Articles.Any())
                                    {
                                        <div class="stack-grid">
                                            @foreach (var article in category.Articles)
                                            {
                                                <div class="info-card">
                                                    <h5 class="mb-1">
                                                        <a asp-action="ViewArticle" asp-route-id="@article.Id">
                                                            @article.Article
                                                        </a>
                                                    </h5>
                                                    <p class="mb-0 text-muted">By @article.Author?.UserName | @article.CreatedAt.ToString("yyyy-MM-dd")</p>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">No articles available in this category.</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
    </section>
</div>

<script>
    function toggleCategory(categoryName) {
        var categoryBody = document.getElementById("category-body-" + categoryName);
        var toggleIcon = categoryBody.previousElementSibling.querySelector('.toggle-icon');
        if (categoryBody.style.display === "none") {
            categoryBody.style.display = "block";
            toggleIcon.style.transform = "rotate(90deg)";
        } else {
            categoryBody.style.display = "none";
            toggleIcon.style.transform = "rotate(0deg)";
        }
    }

    function filterCategories() {
        var input = document.getElementById('categoryFilter');
        var filter = input.value.toUpperCase();
        var container = document.getElementById('category-container');
        var categories = container.getElementsByClassName('category-card');

        Array.from(categories).forEach(function (category) {
            var categoryName = category.querySelector('h4').textContent.toUpperCase();
            category.style.display = categoryName.indexOf(filter) > -1 ? '' : 'none';
        });
    }
</script>
