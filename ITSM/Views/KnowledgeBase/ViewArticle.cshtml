@model ITSM.Models.KnowledgeBaseArticle

<div class="d-grid gap-4">
    <section class="surface-card article-shell">
        <div class="page-header">
            <div>
                <h2 class="mb-1">@Model.Article</h2>
                <p class="text-muted mb-0">
                    <strong>Category:</strong> @Model.Category?.Name |
                    <strong>Author:</strong> @Model.Author?.UserName |
                    <strong>Created:</strong> @Model.CreatedAt.ToShortDateString()
                </p>
            </div>
            <a asp-action="KnowledgeBaseByCategories" class="btn btn-outline-secondary btn-sm">Back</a>
        </div>
        <hr />
        <div>
            @Html.Raw(Model.Content)
        </div>
    </section>
</div>