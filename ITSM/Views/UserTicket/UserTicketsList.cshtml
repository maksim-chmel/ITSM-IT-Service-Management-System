@model IEnumerable<ITSM.Models.Ticket>

@{
    ViewData["Title"] = "All Tickets";
}

<h1>@ViewData["Title"]</h1>

<table class="table">
    <thead>
    <tr>
        <th>Номер</th>
        <th>Title</th> 
        <th>Category</th>
        <th>Description</th>
        <th>Status</th>
        <th>Created At</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var ticket in Model)
    {
        <tr>
            <td>@ticket.Id</td>
            <td>@ticket.Title</td>
            <td>@ticket.Category?.Name</td>
            <td>@ticket.Description</td>
            <td>@ticket.Status</td>
            <td>@ticket.CreatedAt</td>
        </tr>
    }
    </tbody>
</table>