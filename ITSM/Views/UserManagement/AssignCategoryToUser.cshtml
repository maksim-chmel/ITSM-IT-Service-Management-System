@using ITSM.Enums
@model ITSM.ViewModels.Manage.AssignCategoryToUserViewModel

<h2>Assign Categories and Skill Level to: @Model.UserName</h2>

<form asp-controller="UserManagement" asp-action="AssignCategoryToUser" method="post">
    <input type="hidden" asp-for="UserId" />

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-bordered align-middle text-center">
            <thead class="table-dark text-white">
                <tr>
                    <th>Skill Level</th>
                    <th>Selected</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var level in Enum.GetValues(typeof(SkillLevel)).Cast<SkillLevel>())
                {
                    var isChecked = Model.SkillLevel == level; // Check if this level is selected
                    <tr>
                        <td>@level</td>
                        <td>
                            <div class="form-check form-switch d-flex justify-content-center">
                                <input class="form-check-input" type="radio"
                                       name="SkillLevel"
                                       value="@level"
                                       @(isChecked ? "checked" : "") />
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-bordered align-middle text-center">
            <thead class="table-dark text-white">
                <tr>
                    <th>Category</th>
                    <th>Selected</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.Categories)
                {
                    var isChecked = Model.SelectedCategoryIds.Contains(category.Value);
                    <tr>
                        <td>@category.Text</td>
                        <td>
                            <div class="form-check form-switch d-flex justify-content-center">
                                <input class="form-check-input" type="checkbox"
                                       name="SelectedCategoryIds"
                                       value="@category.Value"
                                       @(isChecked ? "checked" : "") />
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between">
        <button type="submit" class="btn btn-outline-primary">Save</button>
        <a asp-controller="UserManagement" asp-action="UsersList" class="btn btn-outline-secondary">Back</a>
    </div>
</form>
