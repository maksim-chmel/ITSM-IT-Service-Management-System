@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<ITSM.Models.Ticket>

@{
    ViewData["Title"] = "All Tickets";
}

<h1>@ViewData["Title"]</h1>

<table class="table">
    <thead>
    <tr>
        <th>Номер</th>
        <th>Title</th>
        <th>Status</th>
        <th>Author Name</th>
        <th>Assigned To</th>
        <th>Created At</th>
        <th>Closed At To</th>
        
        
    </tr>
    </thead>
    <tbody>
    @foreach (var ticket in Model)
    {
        <tr>
            <td>@ticket.Id</td>
            <td>@ticket.Title</td>
            <td>@ticket.Status</td>
            <td>
                @if (ticket.Author != null)
                {
                    @ticket.Author.UserName
                }
            </td>
            <td>@ticket.AssignedUser</td>
            <td>@ticket.CreatedAt</td>
            <td>@ticket.ClosedAt</td>
            
            <td>
                <a asp-controller="AdminTicket" asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-primary">Подробнее</a>
            </td>
        </tr>
        
    }
    </tbody>
</table>