@model ITSM.Models.TicketCategory

<div class="d-grid gap-4">
    <section class="surface-card surface-card--form">
        <div class="page-header">
            <div>
                <h2>Add Category</h2>
                <p class="text-muted mb-0">Create a new top-level ticket category.</p>
            </div>
        </div>

        <form method="post" asp-action="CreateCategory">
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span class="text-danger" asp-validation-for="Name"></span>
            </div>
            <div class="page-actions">
                <button type="submit" class="btn btn-outline-primary">Add Category</button>
                <a asp-controller="TicketCategory" asp-action="CategoryList" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </section>
</div>