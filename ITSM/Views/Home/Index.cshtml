@{
    ViewData["Title"] = "Home Page";
}

<style>
    @@keyframes bounce-left {
        0%, 100% {
            transform: translateX(0);
        }
        50% {
            transform: translateX(15px);
        }
    }

    .arrow-left {
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 40px auto;
        font-size: 80px;
        color: #0d6efd;
        animation: bounce-left 1.5s infinite ease-in-out;
        transition: color 0.3s ease;
        cursor: pointer;
    }

    .arrow-left:hover {
        color: #0a58ca;
    }

    .lead-text {
        font-size: 1.25rem;
        color: #555;
        margin-top: 1rem;
    }
</style>

<div class="container text-center mt-5">
    <h1 class="display-4 fw-bold">IT Process Optimization System</h1>
    <p class="lead-text">Select the section you want to work with using the menu on the left.</p>

    <div class="arrow-left" title="Navigate Left">
        <i class="bi bi-arrow-left-circle-fill"></i>
    </div>
</div>