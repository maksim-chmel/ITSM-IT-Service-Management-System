@model ITSM.ViewModels.Manage.EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="d-grid gap-4">
    <section class="surface-card surface-card--form">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Update basic profile data and roles-related credentials.</p>
            </div>
        </div>

    <form asp-action="EditUser" method="post">
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        }
        <div class="mb-3">
            <label asp-for="UserName" class="form-label">User Name</label>
            <input asp-for="UserName" class="form-control" required/>
            <span asp-validation-for="UserName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" required/>
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
            <input asp-for="PhoneNumber" class="form-control"/>
            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
        </div>

        <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="showPasswordFields"/>
            <label class="form-check-label" for="showPasswordFields">Change Password</label>
        </div>

        <div id="passwordFields" class="password-fields">
            <div class="mb-3">
                <label for="NewPassword" class="form-label">New Password</label>
                <input type="password" class="form-control" id="NewPassword" name="NewPassword"/>
            </div>

            <div class="mb-3">
                <label for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword"/>
            </div>
        </div>

        <div class="page-actions">
            <button type="submit" class="btn btn-outline-primary">Save Changes</button>
            <a asp-controller="UserManagement" asp-action="UsersList" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
    </section>
    </div>
<script>
    const toggle = document.getElementById("showPasswordFields");
    const section = document.getElementById("passwordFields");
    const pwdInputs = section.querySelectorAll("input");

    function setPasswordSectionEnabled(enabled) {
        if (enabled) {
            section.classList.add("show");
            pwdInputs.forEach(i => i.disabled = false);
        } else {
            section.classList.remove("show");
            pwdInputs.forEach(i => { i.disabled = true; i.value = ""; });
        }
    }

    toggle.addEventListener("change", function () {
        setPasswordSectionEnabled(this.checked);
    });

    // Disable on load so auto-filled values aren't accidentally submitted
    setPasswordSectionEnabled(false);
</script>
