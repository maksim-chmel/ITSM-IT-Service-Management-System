@model ITSM.ViewModels.Manage.AssignTicketViewModel

@{
    ViewData["Title"] = "Assign Technician";
}

<h1 class="text-center my-4">@ViewData["Title"]</h1>

<form method="post" asp-controller="TicketAssignment" asp-action="AssignTechnician"
      class="form d-flex justify-content-center">
    <input type="hidden" name="ticketId" value="@Model.Ticket.Id"/>
    <div class="col-md-6">
        <div class="mb-3">
            <label for="userId" class="form-label">Select a technician for assignment:</label>
            <select id="userId" name="userId" class="form-select">
                <option value="">Leave empty</option>
                @foreach (var user in Model.Users)
                {
                    <option value="@user.Value">@user.Text</option>
                }
            </select>
        </div>

        <div class="d-flex gap-3 justify-content-between">
            <button type="submit" class="btn btn-outline-success">Confirm Assignment</button>
            <a asp-controller="TicketAssignment" asp-action="ReviewAllTickets" class="btn btn-outline-secondary">
                Back
            </a>
        </div>
    </div>
</form>