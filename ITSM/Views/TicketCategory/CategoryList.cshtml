@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<ITSM.Models.TicketCategory>

@{
    ViewData["Title"] = "All Tickets";
}

<h1>@ViewData["Title"]</h1>

<table class="table">
    <thead>
    <tr>
        <th>Название</th>
        <th>Действия</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var category in Model)
    {
        <tr>
            <td>@category.Name</td>
            <td>
                <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                        Действия
                    </button>
                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                        <li>
                            <a class="dropdown-item" asp-controller="TicketCategory" asp-action="EditCategory" asp-route-id="@category.Id">Редактировать</a>
                        </li>
                        <li>
                            <form asp-controller="TicketCategory" asp-action="DeleteCategory" asp-route-id="@category.Id" method="post" onsubmit="return confirm('Вы уверены, что хотите удалить категорию? Заявки из этой категории потеряют ее');">
                                <button type="submit" class="dropdown-item text-danger">Удалить</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
    <tr>
        <td colspan="2">
            <a asp-controller="TicketCategory" asp-action="CreateCategory" class="btn btn-primary">Создать</a>
        </td>
    </tr>
    </tbody>
</table>
