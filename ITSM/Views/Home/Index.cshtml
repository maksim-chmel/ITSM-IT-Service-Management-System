@{
    ViewData["Title"] = "Operations Home";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Control Center</div>
        <h1 class="section-title">Work from the left rail. Everything else should feel secondary.</h1>
        <p class="section-copy">
            Your role-specific tools are grouped in the navigation sidebar. Open tickets, knowledge, assignments, or discussions from there and keep the main area focused on the selected task.
        </p>

        <div class="metrics-grid">
            <div class="metric-card">
                <strong>Tickets</strong>
                <span>Create, route, and close requests with tracked ownership and status.</span>
            </div>
            <div class="metric-card">
                <strong>Knowledge</strong>
                <span>Publish repeatable fixes and operational notes for the team.</span>
            </div>
            <div class="metric-card">
                <strong>Discussions</strong>
                <span>Resolve internal coordination questions without leaving the platform.</span>
            </div>
        </div>
    </section>

    <section class="surface-card">
        <h3 class="mb-4">Quick Actions</h3>
        <div class="d-flex flex-wrap gap-3">
            @if (User.IsInRole("User"))
            {
                <a asp-controller="UserTicket" asp-action="CreateTicket" asp-route-categoryId="1" class="btn btn-outline-primary">
                    <i class="bi bi-plus-circle me-1"></i> New Ticket
                </a>
                <a asp-controller="UserTicket" asp-action="UserTicketsList" class="btn btn-outline-secondary">
                    <i class="bi bi-list-ul me-1"></i> My Tickets
                </a>
            }
            @if (User.IsInRole("Technician"))
            {
                <a asp-controller="TechnicianTicket" asp-action="ToDoTicketsList" class="btn btn-outline-primary">
                    <i class="bi bi-wrench me-1"></i> My Queue
                </a>
                <a asp-controller="Discussion" asp-action="ListOfDiscussions" class="btn btn-outline-secondary">
                    <i class="bi bi-chat-text me-1"></i> Discussions
                </a>
            }
            @if (User.IsInRole("Coordinator"))
            {
                <a asp-controller="TicketAssignment" asp-action="ReviewAllTickets" class="btn btn-outline-primary">
                    <i class="bi bi-kanban me-1"></i> Assignment Board
                </a>
                <a asp-controller="Discussion" asp-action="ListOfDiscussions" class="btn btn-outline-secondary">
                    <i class="bi bi-chat-text me-1"></i> Discussions
                </a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="UserManagement" asp-action="UsersList" class="btn btn-outline-primary">
                    <i class="bi bi-people me-1"></i> Users
                </a>
                <a asp-controller="TicketCategory" asp-action="CategoryList" class="btn btn-outline-secondary">
                    <i class="bi bi-tags me-1"></i> Categories
                </a>
                <a asp-controller="Archive" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-archive me-1"></i> Archive
                </a>
            }
            <a asp-controller="KnowledgeBase" asp-action="KnowledgeBaseByCategories" class="btn btn-outline-secondary">
                <i class="bi bi-book me-1"></i> Knowledge Base
            </a>
        </div>
    </section>
</div>
