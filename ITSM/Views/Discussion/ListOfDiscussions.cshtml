@model IEnumerable<ITSM.Models.Discussion>

@{
    ViewData["Title"] = "Discussions";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Team Discussions</div>
        <h1 class="section-title">Open operational threads without mixing them into ticket comments.</h1>
        <p class="section-copy">Use discussion threads for cross-team coordination, resolution proposals, and internal context sharing.</p>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>Open Discussion Topics</h2>
                <p class="text-muted mb-0">Browse active threads or move into creation and archive flows.</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Discussion" asp-action="CreateDiscussion" class="btn btn-outline-secondary"><i class="bi bi-patch-plus"></i> Create</a>
                <a asp-controller="Discussion" asp-action="ResolvedDiscussions" class="btn btn-outline-primary"><i class="bi bi-chat-check"></i> Resolved</a>
            </div>
        </div>

        <form method="get" class="compact-search mb-4">
            <input type="text" name="search" class="form-control" placeholder="Search by title..." value="@Context.Request.Query["search"]" />
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        </form>

        @if (!Model.Any())
        {
            <p class="text-center mb-0">No available discussion topics.</p>
        }
        else
        {
            <div class="discussion-grid">
                @foreach (var thread in Model)
                {
                    <article class="tile-card">
                        <div class="tile-card__icon"><i class="bi bi-chat-text"></i></div>
                        <h5 class="card-title text-truncate">@thread.Title</h5>
                        <p class="card-text">
                            <strong>Author:</strong> @thread.Author?.UserName <br />
                            <strong>Created:</strong> @thread.CreatedAt.ToLocalTime().ToString("g")
                        </p>
                        <a asp-action="ViewDiscussion" asp-route-id="@thread.Id" class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-chat-text"></i> View</a>
                    </article>
                }
            </div>
        }
    </section>
</div>
