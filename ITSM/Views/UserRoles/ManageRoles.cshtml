@model ITSM.ViewModels.Manage.ManageUserRolesViewModel

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Role Control</div>
        <h1 class="section-title">Manage roles for @Model.UserName.</h1>
        <p class="section-copy">Toggle the permission set that defines what this user can access in the platform.</p>
    </section>

    <form asp-controller="UserRoles" asp-action="ManageRoles" method="post" class="stack-grid">
        <input type="hidden" asp-for="UserId" />

        <section class="surface-card">
            <div class="page-header">
                <div>
                    <h3>Available Roles</h3>
                    <p class="text-muted mb-0">Enable or disable access scopes for this user.</p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-center">
                    @{
                        var roleDescriptions = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                        {
                            ["Admin"]       = "Full access — users, categories, roles, archive.",
                            ["Coordinator"] = "Assigns tickets, manages priorities, monitors pipeline.",
                            ["Technician"]  = "Receives and resolves tickets from the queue.",
                            ["User"]        = "Creates support requests and tracks their status.",
                        };
                    }
                    <thead class="table-dark text-white">
                        <tr>
                            <th>Role</th>
                            <th class="text-start">Access Scope</th>
                            <th>Active</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Roles.Count; i++)
                        {
                            var desc = roleDescriptions.GetValueOrDefault(Model.Roles[i].RoleName ?? "", "—");
                            <tr>
                                <td><strong>@Model.Roles[i].RoleName</strong></td>
                                <td class="text-start text-muted small">@desc</td>
                                <td>
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input class="form-check-input" type="checkbox" asp-for="Roles[i].IsSelected" role="switch">
                                        <input type="hidden" asp-for="Roles[i].RoleName" />
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <div class="page-actions">
            <button type="submit" class="btn btn-outline-primary">Save</button>
            <a asp-controller="UserManagement" asp-action="UsersList" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</div>
