@model ITSM.Models.Discussion
<div class="d-grid gap-4">
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h3 class="mb-1">@Model.Title</h3>
                <p class="text-muted mb-0">@Model.Description</p>
            </div>
            <div class="d-flex gap-2">
                <form asp-controller="Archive" asp-action="RestoreDiscussion" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-arrow-counterclockwise"></i> Restore
                    </button>
                </form>
                <a asp-controller="Archive" asp-action="ArchivedDiscussions" class="btn btn-outline-secondary btn-sm">Back to List</a>
            </div>
        </div>

        <p class="small text-muted mb-3">
            <strong>Author:</strong> @(Model.Author?.UserName ?? "N/A") |
            <strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("g") |
            <strong>Closed:</strong> @(Model.ClosedAt?.ToLocalTime().ToString("g") ?? "N/A")
        </p>

        <div class="chat-box mb-3">
            @if (Model.Messages != null && Model.Messages.Any())
            {
                @foreach (var message in Model.Messages.OrderBy(m => m.CreatedAt))
                {
                    <div class="msg-row @(message.AuthorId == Model.AuthorId ? "me" : "other")">
                        <div class="bubble">
                            <div class="msg-header">
                                <span>@message.Author?.UserName</span>
                                <span>@message.CreatedAt.ToLocalTime().ToString("g")</span>
                            </div>
                            <div class="msg-text">@message.Content</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-muted text-center small py-2">No messages yet.</div>
            }
        </div>

        <div class="text-center text-muted small py-2">
            <i class="bi bi-lock-fill"></i> This discussion is archived. Messaging is no longer available.
        </div>
    </section>
</div>
