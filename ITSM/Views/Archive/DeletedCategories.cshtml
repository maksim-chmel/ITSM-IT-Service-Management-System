@model IEnumerable<ITSM.Models.TicketCategory>
@{
    ViewData["Title"] = "Archived Categories";
}

<div class="d-grid gap-4">
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Restore archived categories and their subcategories from a unified list.</p>
            </div>
        </div>

        <form asp-action="RestoreTaxonomy" method="post" id="restoreForm">
            <div class="page-actions mb-3 d-flex justify-content-between">
                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#restoreCategoryModal">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore Selected
                </button>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="selectAll" />
                    <label class="form-check-label" for="selectAll">Select All</label>
                </div>
            </div>

            @{
                var hasDeletedItems = Model.Any(c => c.IsDeleted || c.SubCategories.Any(s => s.IsDeleted));
            }
            @if (!hasDeletedItems)
            {
                <p class="text-center text-muted py-4">
                    <i class="bi bi-tags fs-3 d-block mb-2"></i>
                    No archived categories or subcategories found.
                </p>
            }
            <ul class="list-group">
                @foreach (var category in Model)
                {
                    if (category.IsDeleted || category.SubCategories.Any(s => s.IsDeleted))
                    {
                        <li class="list-group-item">
                            <div class="d-flex align-items-center">
                                @if (category.IsDeleted)
                                {
                                    <input type="checkbox" name="selectedCategoryIds" value="@category.Id" class="form-check-input me-3" data-id="cat-@category.Id"/>
                                }
                                <strong class="flex-grow-1">@category.Name</strong>
                                <span class="badge bg-dark">Category</span>
                            </div>

                            @if (category.SubCategories.Any(s => s.IsDeleted))
                            {
                                <ul class="list-group mt-2 ms-4">
                                    @foreach (var sub in category.SubCategories.Where(s => s.IsDeleted))
                                    {
                                        <li class="list-group-item list-group-item-light">
                                            <div class="d-flex align-items-center">
                                                <input type="checkbox" name="selectedSubCategoryIds" value="@sub.Id" class="form-check-input me-3" data-parent="cat-@category.Id"/>
                                                <span class="flex-grow-1">@sub.Name</span>
                                                <span class="badge bg-secondary">Subcategory</span>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                        </li>
                    }
                }
            </ul>
        </form>
    </section>
</div>

<div class="modal fade" id="restoreCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Restore Selected</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Restore the selected categories and subcategories? They will become active and visible to users again.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmRestoreCategories">Restore</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const selectAll = document.getElementById("selectAll");
            const allCheckboxes = document.querySelectorAll('#restoreForm input[type="checkbox"]');

            selectAll.addEventListener("change", function () {
                allCheckboxes.forEach(cb => cb.checked = this.checked);
            });
            
            allCheckboxes.forEach(cb => cb.addEventListener("change", function () {
                const checked = [...allCheckboxes].filter(c => c.checked).length;
                selectAll.checked = checked === allCheckboxes.length;
                selectAll.indeterminate = checked > 0 && checked < allCheckboxes.length;
            }));

            document.getElementById("confirmRestoreCategories").addEventListener("click", function () {
                document.getElementById("restoreForm").submit();
            });
        });
    </script>
}
