@{
    Layout = "_Layout";
}

<h2 class="text-center my-5">Oops! Something went wrong</h2>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-danger">
                <div class="card-body text-center">
                    <div class="display-1 text-danger">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <h3 class="mt-3">An error occurred</h3>
                    <p class="text-muted mb-4">
                        @if (!string.IsNullOrEmpty(ViewData["ErrorMessage"] as string))
                        {
                            <span>@ViewData["ErrorMessage"]</span>
                        }
                        else
                        {
                            <span>An unexpected error occurred. Please try again later.</span>
                        }
                    </p>
                    <a href="/" class="btn btn-danger">
                        <i class="bi bi-house-door"></i> Go Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>