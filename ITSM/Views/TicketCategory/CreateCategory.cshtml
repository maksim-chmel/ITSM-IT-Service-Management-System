@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ITSM.Models.TicketCategory
<h1 class="text-center mb-4">Add Category</h1>

<form method="post" asp-action="CreateCategory" class="d-flex justify-content-center">
    <div class="col-md-6">
    <div class="mb-3">
        <label for="name" class="form-label">Category Name</label>
        <input type="text" class="form-control" id="name" name="name" value="@(Model?.Name ?? "")" required/>
    </div>
    <div class="d-flex justify-content-between">
        <button type="submit" class="btn btn-outline-success">Add Category</button>
        <a asp-controller="TicketCategory" asp-action="CategoryList" class="btn btn-outline-secondary ">Cancel</a>
    </div>
    </div>
</form>
