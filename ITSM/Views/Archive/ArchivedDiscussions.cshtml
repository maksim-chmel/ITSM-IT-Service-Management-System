@model IEnumerable<ITSM.Models.Discussion>

@{
    ViewData["Title"] = "Resolved Discussions";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Discussion Archive</div>
        <h1 class="section-title">Review historical technical discussions and resolved internal threads.</h1>
        <p class="section-copy">These discussions were automatically or manually resolved and are kept for knowledge sharing.</p>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>Resolved Discussion Topics</h2>
                <p class="text-muted mb-0">Browse resolved discussions and open full history.</p>
            </div>
            <a asp-controller="Archive" asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Archive Hub</a>
        </div>

        <form method="get" class="compact-search mb-4">
            <input type="text" name="search" class="form-control" placeholder="Search by title..." value="@Context.Request.Query["search"]" />
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        </form>

        @if (!Model.Any())
        {
            <p class="text-center mb-0">No available discussion topics.</p>
        }
        else
        {
            <div class="discussion-grid">
                @foreach (var thread in Model)
                {
                    <article class="tile-card">
                        <div class="tile-card__icon"><i class="bi bi-chat-left-check"></i></div>
                        <h5 class="text-truncate">@thread.Title</h5>
                        <p class="small text-muted">
                            <strong>Author:</strong> @thread.Author?.UserName <br />
                            <strong>Created:</strong> @thread.CreatedAt.ToLocalTime().ToString("g") <br />
                            <strong>Closed:</strong> @(thread.ClosedAt?.ToLocalTime().ToString("g") ?? "N/A")
                        </p>
                        <a asp-controller="Archive" asp-action="ViewResolvedDiscussion" asp-route-id="@thread.Id" class="btn btn-outline-primary btn-sm w-100">View History</a>
                    </article>
                }
            </div>
        }
    </section>
</div>
