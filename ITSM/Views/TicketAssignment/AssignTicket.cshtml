@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ITSM.ViewModels.AssignTicketViewModel

@{
    ViewData["Title"] = "Назначить исполнителя";
}

<h1>@ViewData["Title"]</h1>

<form method="post" asp-controller="TicketAssignment" asp-action="AssignTicket" class="form">
    <input type="hidden" name="ticketId" value="@Model.Ticket.Id" />

    <div class="form-group">
        <label for="userId">Выберите пользователя для назначения:</label>
        <select id="userId" name="userId" class="form-control">
            <option value="">Оставить пустым</option>
            @foreach (var user in Model.Users)
            {
                <option value="@user.Value">@user.Text</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label for="priority">Выберите приоритет:</label>
        <select id="priority" name="priority" class="form-control">
            <option value="">Оставить пустым</option>
            @foreach (var priority in Model.Priorities)
            {
                <option value="@priority.Value">@priority.Text</option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-success">Подтвердить изменения</button>
    <a asp-controller="TicketAssignment" asp-action="ReviewTickets" class="btn btn-secondary">Назад</a>
</form>