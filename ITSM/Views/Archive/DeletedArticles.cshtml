@model IEnumerable<ITSM.Models.KnowledgeBaseArticle>
@{
    ViewData["Title"] = "Archived Articles";
}

<div class="d-grid gap-4">
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Restore archived knowledge articles back to active library.</p>
            </div>
        </div>
        <form asp-action="RestoreArticles" method="post">
            <div class="page-actions mb-3">
                <button type="submit" id="restoreBtn" class="btn btn-outline-primary" disabled>
                    <i class="bi bi-arrow-counterclockwise"></i> Restore Selected
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-center">
                    <thead class="table-dark text-white">
                    <tr>
                        <th><input type="checkbox" id="selectAll" /></th>
                        <th>#</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Author</th>
                        <th>Created At</th>
                    </tr>
                    </thead>
                    <tbody class="table-light">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-journal-x fs-3 d-block mb-2"></i>
                                No archived articles found.
                            </td>
                        </tr>
                    }
                    @foreach (var article in Model)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" name="selectedArticleIds" value="@article.Id" class="form-check-input" />
                            </td>
                            <td><strong>@article.Id</strong></td>
                            <td>@article.Article</td>
                            <td>@article.Category?.Name</td>
                            <td>@article.Author?.UserName</td>
                            <td>@article.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        const selectAll = document.getElementById("selectAll");
        const checkboxes = document.querySelectorAll('input[name="selectedArticleIds"]');
        const restoreBtn = document.getElementById("restoreBtn");

        function updateRestoreBtn() {
            restoreBtn.disabled = ![...checkboxes].some(c => c.checked);
        }

        selectAll.addEventListener("change", function () {
            checkboxes.forEach(cb => cb.checked = this.checked);
            updateRestoreBtn();
        });

        checkboxes.forEach(cb => cb.addEventListener("change", function () {
            const checked = [...checkboxes].filter(c => c.checked).length;
            selectAll.checked = checked === checkboxes.length;
            selectAll.indeterminate = checked > 0 && checked < checkboxes.length;
            updateRestoreBtn();
        }));
    </script>
}
