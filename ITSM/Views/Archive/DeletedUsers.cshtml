@model IEnumerable<ITSM.Models.User>

<div class="d-grid gap-4">
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>Restore Deleted Users</h2>
                <p class="text-muted mb-0">Select users to restore access and profile visibility.</p>
            </div>
        </div>

        <form asp-action="RestoreUsers" method="post">
            <div class="page-actions mb-3">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore Selected
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-center">
                    <thead class="table-dark text-white">
                    <tr>
                        <th><input type="checkbox" id="selectAll" /></th>
                        <th>#</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Is Deleted</th>
                    </tr>
                    </thead>
                    <tbody class="table-light">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" name="selectedUserIds" value="@user.Id" class="form-check-input" />
                            </td>
                            <td><strong>@user.Id</strong></td>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>@user.IsDeleted</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        const selectAll = document.getElementById("selectAll");
        const checkboxes = document.querySelectorAll('input[name="selectedUserIds"]');

        selectAll.addEventListener("change", function () {
            checkboxes.forEach(cb => cb.checked = this.checked);
        });

        checkboxes.forEach(cb => cb.addEventListener("change", function () {
            const total = checkboxes.length;
            const checked = [...checkboxes].filter(c => c.checked).length;
            selectAll.checked = checked === total;
            selectAll.indeterminate = checked > 0 && checked < total;
        }));
    </script>
}