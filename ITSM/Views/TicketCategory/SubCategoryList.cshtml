@model ITSM.ViewModels.Create.SubCategoryCreateViewModel

@{
  
    var category = (ITSM.Models.TicketCategory)ViewData["Category"]!;
    ViewData["Title"] = category.Name;
}

<div class="d-grid gap-4">
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Manage subcategories for this category.</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-dark text-white">
                    <tr>
                        <th>Subcategory Title</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="table-light">
                    @foreach (var subCategory in category.SubCategories)
                    {
                        <tr>
                            <td>@subCategory.Name</td>
                            <td>
                                <form asp-controller="TicketCategory" asp-action="DeleteSubCategory" asp-route-subCategoryId="@subCategory.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this subcategory?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <form asp-controller="TicketCategory" asp-action="AddSubCategory" method="post" class="surface-card--form mt-3">
            <input type="hidden" asp-for="CategoryId" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Subcategory Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="page-actions">
                <button type="submit" class="btn btn-outline-primary">Add Subcategory</button>
                <a asp-controller="TicketCategory" asp-action="CategoryList" class="btn btn-outline-secondary">Back to Categories</a>
            </div>
        </form>
    </section>
</div>
