@model IEnumerable<ITSM.Models.KnowledgeBaseArticle>

@{
    ViewData["Title"] = "My Articles";
}

<h2 class="text-center mb-4">@ViewData["Title"]</h2>
<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover table-bordered align-middle text-center">
        <thead class="table-dark text-white">
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>Category</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody class="table-light">
        @foreach (var article in Model)
        {
            <tr>
                <td>@article.Article</td>
                <td>@article.Author?.UserName</td>
                <td>@article.Category?.Name</td>
                <td>@article.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-action="EditArticle" asp-route-id="@article.Id"
                       class="btn btn-outline-primary btn-sm">Edit</a>
                    <form asp-action="DeleteArticle" asp-route-id="@article.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<a asp-action="CreateArticle" class="btn btn-outline-success btn-sm">Create</a>