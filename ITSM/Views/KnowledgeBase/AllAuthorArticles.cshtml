@model IEnumerable<ITSM.Models.KnowledgeBaseArticle>

@{
    ViewData["Title"] = "My Articles";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Knowledge Authoring</div>
        <h1 class="section-title">Manage the articles you published for the support team.</h1>
        <p class="section-copy">Keep documentation current so repeated incidents can be resolved faster and more consistently.</p>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Review, update, or remove articles you authored.</p>
            </div>
            <a asp-action="CreateArticle" class="btn btn-outline-primary btn-sm">Create</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-dark text-white">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Category</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody class="table-light">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-journal-x fs-3 d-block mb-2"></i>
                            You haven't published any articles yet.
                            <a asp-action="CreateArticle" class="ms-1">Write your first one.</a>
                        </td>
                    </tr>
                }
                @foreach (var article in Model)
                {
                    <tr>
                        <td>@article.Article</td>
                        <td>@article.Author?.UserName</td>
                        <td>@article.Category?.Name</td>
                        <td>@article.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <a asp-action="EditArticle" asp-route-id="@article.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#archiveArticleModal"
                                    data-action="@Url.Action("ArchiveArticle", "KnowledgeBase", new { id = article.Id })"
                                    data-title="@article.Article">
                                Archive
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

<form id="archiveArticleForm" method="post">
    @Html.AntiForgeryToken()
</form>

<div class="modal fade" id="archiveArticleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Archive Article</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Archive <strong id="archiveArticleTitle"></strong>? It will be moved to the recovery zone and hidden from the knowledge base.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="archiveArticleConfirm">Archive</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("archiveArticleModal").addEventListener("show.bs.modal", function (e) {
            const btn = e.relatedTarget;
            document.getElementById("archiveArticleTitle").textContent = btn.dataset.title;
            document.getElementById("archiveArticleForm").action = btn.dataset.action;
        });
        document.getElementById("archiveArticleConfirm").addEventListener("click", function () {
            document.getElementById("archiveArticleForm").submit();
        });
    </script>
}
