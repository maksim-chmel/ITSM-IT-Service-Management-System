@using ITSM.Enums
@model ITSM.ViewModels.Manage.TicketDetailsViewModel
@if (TempData["TicketClosed"] != null)
{
    <div class="alert alert-success" role="alert">
        Ticket successfully resolved.
    </div>
}
<div class="mt-4">
    <a asp-controller="TechnicianTicket" asp-action="ToDoTicketsList" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
</div>
<h1 class="text-center my-4"></h1>

<div class="table-responsive shadow-sm rounded mb-4">
    <table class="table table-bordered table-hover align-middle">
        <tbody>
            <tr>
                <th>Ticket Number:</th>
                <td>@Model.Ticket.Id</td>
            </tr>
            <tr>
                <th>Title:</th>
                <td>@Model.Ticket.Title</td>
            </tr>
            <tr>
                <th>Description:</th>
                <td>@Model.Ticket.Description</td>
            </tr>
            <tr>
                <th>Created At:</th>
                <td>@Model.Ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
            <tr>
                <th>Author:</th>
                <td>@Model.Ticket.Author?.UserName</td>
            </tr>
            <tr>
                <th>Assigned To:</th>
                <td>@Model.Ticket.AssignedUser</td>
            </tr>
            <tr>
                <th>Fix Description:</th>
                <td>@Model.Ticket.FixDescription</td>
            </tr>
            <tr>
                <th>Status:</th>
                <td>@Model.Ticket.Status</td>
            </tr>
        </tbody>
    </table>
</div>

<h3 class="mb-3">Notes</h3>
<div class="table-responsive shadow-sm rounded mb-4">
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Note</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var note in Model.TicketHistory)
            {
                <tr>
                    <td>@note.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@note.AdminComment</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.Ticket.Status == Status.Progress)
{
    <div class="d-flex gap-3">
        <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addNoteModal">
            Add Note
        </button>

        <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#closeTicketModal">
            Mark as Resolved
        </button>
    </div>
    
    <div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addNoteModalLabel">Add Note</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" asp-controller="TechnicianTicket" asp-action="AddNewCommentToTicket">
                        <input type="hidden" name="ticketId" value="@Model.Ticket.Id"/>
                        <div class="mb-3">
                            <label for="noteDescription" class="form-label">Note:</label>
                            <textarea class="form-control" id="noteDescription" name="adminComment" rows="3" placeholder="Add a note" required></textarea>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Save Note</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="closeTicketModal" tabindex="-1" aria-labelledby="closeTicketLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="closeTicketLabel">Resolution Description</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form method="post" asp-controller="TechnicianTicket" asp-action="ResolveTicket">
                        <input type="hidden" name="id" value="@Model.Ticket.Id"/>
                        <div class="mb-3">
                            <label for="solution" class="form-label">Solution</label>
                            <textarea class="form-control" id="solution" name="solution" required></textarea>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Confirm</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}


