@using ITSM.Enums
@using ITSM.ViewModels.Manage
@using System.Text.Json;
@model IEnumerable<ITSM.Models.Ticket>

@{
    ViewData["Title"] = "Coordinator Dashboard";

    // --- Data for KPI Cards ---
    var totalTickets = Model.Count();
    var unassignedTickets = Model.Count(t => t.AssignedUserId == null && t.Status != Status.Resolved && t.Status != Status.Canceled);
    var inProgressTickets = Model.Count(t => t.Status == Status.Progress);

    // --- Data for Charts ---
    var statusGroups = Model.GroupBy(t => t.Status).ToDictionary(g => g.Key, g => g.Count());
    var statusLabels = statusGroups.Keys.Select(s => s.ToString()).ToArray();
    var statusData = statusGroups.Values.ToArray();
    var statusColors = statusGroups.Keys.Select(s => s switch {
        Status.New => "#0d6efd", Status.Open => "#0dcaf0", Status.Progress => "#ffc107",
        Status.OnHold => "#6c757d", Status.Reopened => "#dc3545", Status.Resolved => "#198754",
        _ => "#adb5bd"
    }).ToArray();

    var workloadGroups = Model
        .Where(t => t.AssignedUser != null && t.Status != Status.Resolved && t.Status != Status.Canceled)
        .GroupBy(t => t.AssignedUser!.UserName ?? "Unassigned")
        .ToDictionary(g => g.Key, g => g.Count());
    var workloadLabels = workloadGroups.Keys.ToArray();
    var workloadData = workloadGroups.Values.ToArray();

    // --- Helpers ---
    Func<Status, string> getBadgeClass = status => status switch {
        Status.New => "bg-primary", Status.Open => "bg-info", Status.Progress => "bg-warning text-dark",
        Status.OnHold => "bg-secondary", Status.Reopened => "bg-danger", Status.Resolved => "bg-success",
        Status.Canceled => "bg-dark", _ => "bg-light text-dark"
    };
    Func<TicketPriority, string> priorityBadgeClass = priority => priority switch {
        TicketPriority.Low => "bg-secondary", TicketPriority.Medium => "bg-primary",
        TicketPriority.High => "bg-warning text-dark", TicketPriority.Critical => "bg-danger",
        _ => "bg-dark"
    };
}

<div class="d-grid gap-4">
    <!-- Header -->
    <section class="page-hero">
        <div class="eyebrow">Coordinator Desk</div>
        <h1 class="section-title">Ticket Assignment & Pipeline Overview</h1>
    </section>

    <!-- KPI Cards -->
    <section class="kpi-grid">
        <div class="kpi-card">
            <i class="bi bi-ticket-detailed"></i>
            <div class="kpi-value">@totalTickets</div>
            <div class="kpi-label">Total Active Tickets</div>
        </div>
        <div class="kpi-card">
            <i class="bi bi-person-plus"></i>
            <div class="kpi-value">@unassignedTickets</div>
            <div class="kpi-label">Unassigned</div>
        </div>
        <div class="kpi-card">
            <i class="bi bi-person-workspace"></i>
            <div class="kpi-value">@inProgressTickets</div>
            <div class="kpi-label">In Progress</div>
        </div>
        <div class="kpi-card-actions">
             <h5>Actions</h5>
             <div class="action-grid">
                 <form asp-action="AssignTickets" method="post" class="d-grid">
                     <button type="submit" class="btn btn-success"><i class="bi bi-magic"></i> Auto-Assign</button>
                 </form>
                 <form asp-action="ResetTickets" method="post" class="d-grid">
                     <button type="submit" class="btn btn-outline-danger"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
                 </form>
             </div>
        </div>
    </section>

    <!-- Dashboard Charts -->
    <section class="dashboard-grid">
        <div class="chart-card large">
            <h5>Technician Workload</h5>
            <p class="text-muted small">Number of active tickets per technician.</p>
            @if (workloadLabels.Length == 0)
            {
                <div class="d-flex align-items-center justify-content-center text-muted" style="height:300px;">
                    <div class="text-center">
                        <i class="bi bi-bar-chart fs-1 d-block mb-2"></i>
                        No active tickets are assigned to any technician.
                    </div>
                </div>
            }
            else
            {
                <div class="chart-container" style="height:300px;">
                    <canvas id="workloadChart"></canvas>
                </div>
            }
        </div>
        <div class="chart-card">
            <h5>Status Distribution</h5>
            <div class="chart-container" style="height:300px; position:relative;">
                <canvas id="statusChart"></canvas>
                <div class="chart-center-text">
                    <strong>@totalTickets</strong>
                    <span>Total</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Table -->
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2 class="mb-1">Ticket Queue</h2>
                <p class="text-muted mb-0">Manage individual tickets below.</p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle text-center">
                 <thead class="table-dark text-white">
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Category</th>
                    <th>Assigned To</th>
                    <th>Created At</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody class="table-light">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="bi bi-ticket fs-3 d-block mb-2"></i>
                            No active tickets in the pipeline.
                        </td>
                    </tr>
                }
                @foreach (var ticket in Model)
                {
                    var isActionable = ticket.Status != Status.Resolved && ticket.Status != Status.Canceled;
                    <tr data-ticket-row="@ticket.Id">
                        <td><a asp-controller="TicketAssignment" asp-action="InfoAboutTicket" asp-route-id="@ticket.Id"><strong>@ticket.Id</strong></a></td>
                        <td class="text-truncate" style="max-width: 200px;" title="@ticket.Title">@ticket.Title</td>
                        <td><span class="badge @getBadgeClass(ticket.Status)">@ticket.Status</span></td>
                        <td><span class="badge @priorityBadgeClass(ticket.Priority)">@ticket.Priority</span></td>
                        <td>@ticket.Category?.Name</td>
                        <td>@(ticket.AssignedUser?.UserName ?? "Unassigned")</td>
                        <td>@ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (isActionable)
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary js-manage-btn"
                                        data-ticket-id="@ticket.Id">Manage</button>
                            }
                            else
                            {
                                <span class="btn btn-sm btn-outline-secondary disabled"
                                      data-bs-toggle="tooltip" title="Ticket is @ticket.Status — no actions available">
                                    Manage
                                </span>
                            }
                        </td>
                    </tr>
                }
                <tr id="management-row" class="d-none">
                    <td colspan="8" class="p-0" id="management-panel-content"></td>
                </tr>
                </tbody>
            </table>
        </div>
    </section>
</div>

<style>
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
    .kpi-card, .kpi-card-actions { background: var(--panel-strong); border-radius: var(--radius-sm); padding: 1.5rem; border: 1px solid var(--line); text-align: center; }
    .kpi-card i { font-size: 2.5rem; color: var(--brand); margin-bottom: 0.5rem; }
    .kpi-value { font-size: 2.5rem; font-weight: 700; }
    .kpi-label { font-size: 1rem; color: var(--muted); }
    .kpi-card-actions h5 { margin-bottom: 1rem; }
    .chart-container { position: relative; width: 100%; }
    .chart-center-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; line-height: 1.2; }
    .chart-center-text strong { font-size: 2.5rem; }
    .chart-center-text span { font-size: 1rem; color: var(--muted); }
    .management-panel { background: var(--bg); padding: 1rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; border-top: 2px solid var(--line); }
    .management-form h5 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Bootstrap tooltips
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el =>
                new bootstrap.Tooltip(el));

            // AJAX Management Panel
            const mgmtRow     = document.getElementById("management-row");
            const mgmtContent = document.getElementById("management-panel-content");
            let   activeTicketId = null;

            document.querySelectorAll(".js-manage-btn").forEach(btn => {
                btn.addEventListener("click", async function () {
                    const ticketId  = this.dataset.ticketId;
                    const ticketRow = document.querySelector(`tr[data-ticket-row="${ticketId}"]`);

                    if (activeTicketId === ticketId) {
                        mgmtRow.classList.add("d-none");
                        activeTicketId = null;
                        document.querySelectorAll(".js-manage-btn").forEach(b => b.classList.remove("btn-secondary"));
                        this.classList.remove("btn-secondary");
                        this.classList.add("btn-outline-primary");
                        this.textContent = "Manage";
                        return;
                    }

                    document.querySelectorAll(".js-manage-btn").forEach(b => {
                        b.classList.remove("btn-secondary");
                        b.classList.add("btn-outline-primary");
                        b.textContent = "Manage";
                    });
                    this.classList.remove("btn-outline-primary");
                    this.classList.add("btn-secondary");
                    this.textContent = "Close";

                    mgmtContent.innerHTML = '<div class="skeleton-panel"><div><div class="skel-block skel-label"></div><div class="skel-block skel-input"></div></div><div><div class="skel-block skel-label"></div><div class="skel-block skel-input"></div></div></div>';
                    ticketRow.insertAdjacentElement("afterend", mgmtRow);
                    mgmtRow.classList.remove("d-none");
                    activeTicketId = ticketId;

                    try {
                        const resp = await fetch(`/TicketAssignment/ManagementPanel?ticketId=${ticketId}`, {
                            headers: { "X-Requested-With": "XMLHttpRequest" }
                        });
                        if (!resp.ok) {
                            const err = await resp.json().catch(() => ({ error: "Unknown error" }));
                            mgmtContent.innerHTML = `<div class="p-3 text-danger"><i class="bi bi-exclamation-circle me-1"></i>${err.error}</div>`;
                            return;
                        }
                        mgmtContent.innerHTML = await resp.text();

                        mgmtContent.querySelectorAll("form").forEach(form => {
                            form.addEventListener("submit", async function (e) {
                                e.preventDefault();
                                const submitBtn = form.querySelector("[type=submit]");
                                if (submitBtn) submitBtn.disabled = true;
                                const formData = new FormData(form);
                                const action   = form.action;
                                try {
                                    const r = await fetch(action, { method: "POST", body: formData });
                                    if (r.redirected || r.ok) {
                                        location.reload();
                                    } else {
                                        const err = await r.json().catch(() => ({ error: "Error submitting form." }));
                                        mgmtContent.innerHTML = `<div class="p-3 text-danger"><i class="bi bi-exclamation-circle me-1"></i>${err.error}</div>`;
                                    }
                                } catch {
                                    location.reload();
                                }
                            });
                        });
                    } catch {
                        mgmtContent.innerHTML = '<div class="p-3 text-danger"><i class="bi bi-exclamation-circle me-1"></i>Failed to load management panel.</div>';
                    }
                });
            });

            // Common Chart Options
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { padding: 20 }
                    }
                }
            };

            // Status Doughnut Chart
            const statusCtx = document.getElementById('statusChart')?.getContext('2d');
            if (statusCtx) {
                new Chart(statusCtx, {
                    type: 'doughnut',
                    data: {
                        labels: @Html.Raw(JsonSerializer.Serialize(statusLabels)),
                        datasets: [{
                            data: @Html.Raw(JsonSerializer.Serialize(statusData)),
                            backgroundColor: @Html.Raw(JsonSerializer.Serialize(statusColors)),
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: { ...commonOptions, cutout: '70%' }
                });
            }

            // Workload Bar Chart
            const workloadCtx = document.getElementById('workloadChart')?.getContext('2d');
            if(workloadCtx) {
                const brandColor = getComputedStyle(document.documentElement).getPropertyValue('--brand').trim();
                 new Chart(workloadCtx, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(JsonSerializer.Serialize(workloadLabels)),
                        datasets: [{
                            label: 'Active Tickets',
                            data: @Html.Raw(JsonSerializer.Serialize(workloadData)),
                            backgroundColor: brandColor,
                        }]
                    },
                    options: {
                        ...commonOptions,
                        indexAxis: 'y',
                         plugins: { legend: { display: false } },
                         scales: { x: { grid: { display: false } }, y: { grid: { display: false } } }
                    }
                });
            }
        });
    </script>
}
