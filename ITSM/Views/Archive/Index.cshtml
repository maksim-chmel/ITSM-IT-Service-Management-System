@{
    ViewData["Title"] = "Archive";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Recovery Zone</div>
        <h1 class="section-title">Review deleted entities and restore them when the workflow requires it.</h1>
        <p class="section-copy">Use the archive hub to inspect soft-deleted content across articles, tickets, categories, and users.</p>
    </section>

    <section class="archive-grid">
        <a asp-controller="Archive" asp-action="DeletedArticles" class="archive-link">
            <i class="bi bi-journal-text"></i>
            <strong>Articles Archive</strong>
            <span class="text-muted">Review removed knowledge base entries.</span>
        </a>

        <a asp-controller="Archive" asp-action="DeletedTickets" class="archive-link">
            <i class="bi bi-ticket-perforated"></i>
            <strong>Tickets Archive</strong>
            <span class="text-muted">Inspect and restore canceled or archived ticket records.</span>
        </a>

        <a asp-controller="Archive" asp-action="DeletedCategories" class="archive-link">
            <i class="bi bi-tags"></i>
            <strong>Categories Archive</strong>
            <span class="text-muted">Recover removed taxonomies and supporting structure.</span>
        </a>

        <a asp-controller="Archive" asp-action="DeletedUsers" class="archive-link">
            <i class="bi bi-person-x"></i>
            <strong>Users Archive</strong>
            <span class="text-muted">Restore soft-deleted accounts when access needs to be recovered.</span>
        </a>
    </section>
</div>
