@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ITSM.ViewModels.ManageUserRolesViewModel

<h2>Manage Roles: @Model.UserName</h2>

<form asp-controller="UserRoles" asp-action="ManageRoles" method="post">
    <input type="hidden" asp-for="UserId" />

    <div class="table-responsive shadow-sm rounded">
    <table class="table table-hover table-bordered align-middle text-center">
            <thead class="table-dark text-white">
            <tr>
                <th>Role</th>
                <th>Selected</th>
            </tr>
            </thead>
            <tbody>
            @for (var i = 0; i < Model.Roles.Count; i++)
            {
                <tr>
                    <td>@Model.Roles[i].RoleName</td>
                    <td>
                        <div class="form-check form-switch d-flex justify-content-center">
                            <input class="form-check-input" type="checkbox" asp-for="Roles[i].IsSelected" role="switch">
                            <input type="hidden" asp-for="Roles[i].RoleName" />
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between">
        <button type="submit" class="btn btn-outline-primary">Save</button>
        <a asp-controller="UserManagement" asp-action="UsersList" class="btn btn-outline-secondary">Back</a>
    </div>
</form>
