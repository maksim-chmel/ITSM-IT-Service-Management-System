@using ITSM.Enums
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<ITSM.Models.Ticket>

@{
    ViewData["Title"] = "Ticket Assignment";
}
<h2 class="text-center mb-4">@ViewData["Title"]</h2>

<div class="mb-3">
    <div class="dropdown">
        <button class="btn btn-outline-primary dropdown-toggle" type="button" id="filterDropdown"
                data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-funnel"></i> Filters
        </button>

       
        <div class="dropdown-menu p-3" style="min-width: 250px;">
            <form method="get" class="row g-2">
               
                <div class="col-12">
                    <label class="form-label small mb-1">Category</label>
                    <select name="CategoryId" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var category in (ViewBag.Categories as List<SelectListItem>)!)
                        {
                            <option value="@category.Value">@category.Text</option>
                        }
                    </select>
                </div>

               
                <div class="col-12">
                    <label class="form-label small mb-1">Priority</label>
                    <select name="Priority" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var p in Enum.GetValues(typeof(ITSM.Enums.TicketPriority)))
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>

             
                <div class="col-12">
                    <label class="form-label small mb-1">Status</label>
                    <select name="Status" class="form-select form-select-sm">
                        <option value="">All</option>
                        @foreach (var s in Enum.GetValues(typeof(ITSM.Enums.TicketStatus)))
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>

               
                <div class="col-12 d-grid">
                    <button type="submit" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-search"></i> Apply
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover table-bordered align-middle text-center">
        <thead class="table-dark text-white">
        <tr>
            <th>#</th>
            <th>Title</th>
            <th>Status</th>
            <th>Priority</th>
            <th>Category</th>
            <th>SubCategory</th>
            <th>Author Name</th>
            <th>Assigned To</th>
            <th>Created At</th>
            <th>Closed At</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody class="table-light">
        @foreach (var ticket in Model)
        {
            <tr>
                <td><strong>@ticket.Id</strong></td>
                <td class="text-truncate" style="max-width: 200px;" title="@ticket.Title">@ticket.Title</td>


                <td>
                        <span class="badge 
                            @(ticket.Status == TicketStatus.Open ? "bg-primary text-white" :
                                                                 ticket.Status == TicketStatus.Progress ? "bg-info text-white" :
                                                                 ticket.Status == TicketStatus.Resolved ? "bg-success text-white" :
                                                                 ticket.Status == TicketStatus.Reopened ? "bg-warning text-white" :
                                                                 ticket.Status == TicketStatus.Canceled ? "bg-danger text-white" :
                                                                 ticket.Status == TicketStatus.Done ? "bg-secondary text-white" : "bg-dark")">
                            @ticket.Status
                        </span>
                </td>


                <td>
                        <span class="badge 
                            @(ticket.Priority == TicketPriority.Low ? "bg-secondary text-white" :
                                                                 ticket.Priority == TicketPriority.Medium ? "bg-primary text-white" :
                                                                 ticket.Priority == TicketPriority.High ? "bg-warning text-white" :
                                                                 ticket.Priority == TicketPriority.Critical ? "bg-danger text-white" : "bg-dark text-white")">
                            @ticket.Priority
                        </span>
                </td>

                <td>@ticket.Category?.Name</td>
                <td>@ticket.TicketSubCategory?.Name</td>
                <td>@ticket.Author?.UserName</td>
                <td>@ticket.AssignedUser</td>
                <td>@ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@(ticket.ClosedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>


                <td>
                    @if (ticket.Status != TicketStatus.Canceled)
                    {
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle" type="button"
                                    id="ticketActionsDropdown"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                Actions
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="ticketActionsDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="TicketAssignment"
                                       asp-action="InfoAboutTicket"
                                       asp-route-id="@ticket.Id">
                                        Information
                                    </a>
                                </li>
                                @if (ticket.Status != TicketStatus.Done)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="TicketAssignment"
                                           asp-action="AssignTicket"
                                           asp-route-id="@ticket.Id">
                                            Manage
                                        </a>
                                    </li>
                                    <li>
                                        <button class="dropdown-item text-danger" type="button" data-bs-toggle="modal"
                                                data-bs-target="#cancelTicketModal-@ticket.Id">
                                            Cancel Ticket
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </td>
            </tr>


            <div class="modal fade" id="cancelTicketModal-@ticket.Id" tabindex="-1"
                 aria-labelledby="cancelTicketModalLabel"
                 aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="cancelTicketModalLabel">Cancel Ticket</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form method="post" asp-controller="TicketAssignment" asp-action="CancelTicket">
                                <input type="hidden" name="id" value="@ticket.Id"/>
                                <div class="mb-3">
                                    <label for="reason" class="form-label">Reason for Cancellation:</label>
                                    <textarea class="form-control" id="reason" name="reason" rows="3"
                                              placeholder="Please provide a reason for canceling the ticket"
                                              required></textarea>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                        Cancel
                                    </button>
                                    <button type="submit" class="btn btn-outline-danger">Cancel Ticket</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
        </tbody>
    </table>
</div>
