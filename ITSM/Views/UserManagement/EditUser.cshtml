@model ITSM.ViewModels.Manage.EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="d-grid gap-4">
    <section class="surface-card surface-card--form">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Update basic profile data and roles-related credentials.</p>
            </div>
        </div>

    <form asp-action="EditUser" method="post">
        <div class="mb-3">
            <label for="UserName" class="form-label">User Name</label>
            <input type="text" class="form-control" id="UserName" name="UserName" value="@Model.UserName" required/>
        </div>

        <div class="mb-3">
            <label for="Email" class="form-label">Email</label>
            <input type="email" class="form-control" id="Email" name="Email" value="@Model.Email" required/>
        </div>

        <div class="mb-3">
            <label for="PhoneNumber" class="form-label">Phone Number</label>
            <input type="text" class="form-control" id="PhoneNumber" name="PhoneNumber" value="@Model.PhoneNumber" required/>
        </div>

        <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="showPasswordFields"/>
            <label class="form-check-label" for="showPasswordFields">Change Password</label>
        </div>

        <div id="passwordFields" class="password-fields">
            <div class="mb-3">
                <label for="NewPassword" class="form-label">New Password</label>
                <input type="password" class="form-control" id="NewPassword" name="NewPassword"/>
            </div>

            <div class="mb-3">
                <label for="ConfirmPassword" class="form-label">Confirm New Password</label>
                <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword"/>
            </div>
        </div>

        <div class="page-actions">
            <button type="submit" class="btn btn-outline-primary">Save Changes</button>
            <a asp-controller="UserManagement" asp-action="UsersList" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
    </section>
    </div>
<script>
    document.getElementById("showPasswordFields").addEventListener("change", function() {
        var passwordFields = document.getElementById("passwordFields");
        if (this.checked) {
            passwordFields.classList.add("show");
        } else {
            passwordFields.classList.remove("show");
        }
    });
</script>
