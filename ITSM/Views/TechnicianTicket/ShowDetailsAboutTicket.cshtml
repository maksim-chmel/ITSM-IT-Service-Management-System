@using ITSM.Enums
@model ITSM.ViewModels.Manage.TicketDetailsViewModel
@if (TempData["TicketClosed"] != null)
{
    <div class="alert alert-success" role="alert">
        Ticket successfully resolved.
    </div>
}

<div class="d-grid gap-4">
    <div class="page-actions">
        <a asp-controller="TechnicianTicket" asp-action="ToDoTicketsList" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Queue
        </a>
    </div>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>Ticket #@Model.Ticket.Id</h2>
                <p class="text-muted mb-0">Technician detail view for execution notes and resolution actions.</p>
            </div>
            <span class="badge bg-info text-white">@Model.Ticket.Status</span>
        </div>
        <div class="info-grid">
            <div class="info-card"><dl><dt>Title</dt><dd>@Model.Ticket.Title</dd></dl></div>
            <div class="info-card"><dl><dt>Author</dt><dd>@Model.Ticket.Author?.UserName</dd></dl></div>
            <div class="info-card"><dl><dt>Created At</dt><dd>@Model.Ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd></dl></div>
            <div class="info-card"><dl><dt>Assigned To</dt><dd>@Model.Ticket.AssignedUser</dd></dl></div>
            <div class="info-card"><dl><dt>Fix Description</dt><dd>@(string.IsNullOrWhiteSpace(Model.Ticket.FixDescription) ? "-" : Model.Ticket.FixDescription)</dd></dl></div>
            <div class="info-card"><dl><dt>Description</dt><dd>@Model.Ticket.Description</dd></dl></div>
        </div>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h3>Notes</h3>
                <p class="text-muted mb-0">Operational comments captured while the ticket is in progress.</p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Note</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var note in Model.TicketHistory)
                    {
                        <tr>
                            <td>@note.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@note.AdminComment</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @if (Model.Ticket.Status == Status.Progress)
    {
        <div class="page-actions">
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                Add Note
            </button>

            <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#closeTicketModal">
                Mark as Resolved
            </button>
        </div>

        <div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addNoteModalLabel">Add Note</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form method="post" asp-controller="TechnicianTicket" asp-action="AddNewCommentToTicket">
                            <input type="hidden" name="ticketId" value="@Model.Ticket.Id"/>
                            <div class="mb-3">
                                <label for="noteDescription" class="form-label">Note:</label>
                                <textarea class="form-control" id="noteDescription" name="adminComment" rows="3" placeholder="Add a note" required></textarea>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save Note</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="closeTicketModal" tabindex="-1" aria-labelledby="closeTicketLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="closeTicketLabel">Resolution Description</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form method="post" asp-controller="TechnicianTicket" asp-action="ResolveTicket">
                            <input type="hidden" name="id" value="@Model.Ticket.Id"/>
                            <div class="mb-3">
                                <label for="solution" class="form-label">Solution</label>
                                <textarea class="form-control" id="solution" name="solution" required></textarea>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Confirm</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
