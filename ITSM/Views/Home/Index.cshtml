@{
    ViewData["Title"] = "Головна сторінка";
}

<style>
    @@keyframes bounce-left {
        0%, 100% {
            transform: translateX(0);
        }
        50% {
            transform: translateX(15px); 
        }
    }

    .arrow-down {
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 40px auto;
        font-size: 80px;
        animation: bounce-left 1.5s infinite;
        color: #0d6efd;
        transition: color 0.3s;
    }

    .arrow-down:hover {
        color: #0a58ca;
    }
</style>

<div class="container text-center mt-5">
    <h1 class="display-4">Система оптимізації ІТ-процесів</h1>
    <p class="lead mt-3">Оберіть розділ, з яким хочете працювати, використовуючи меню зліва</p>

    <div class="arrow-down">
        <i class="bi bi-arrow-left-circle-fill"></i> <!-- Изменена иконка на стрелку влево -->
    </div>
</div>