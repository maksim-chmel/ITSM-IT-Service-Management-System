@using ITSM.Enums
@model IEnumerable<ITSM.Models.Ticket>

@{
    ViewData["Title"] = "Ticket Assignment";
    
    var statusGroups = Model
        .GroupBy(t => t.Status)
        .ToDictionary(g => g.Key, g => g.Count());

    var allStatuses = Enum.GetValues(typeof(Status)).Cast<Status>().ToList();
    var statusLabels = allStatuses.Select(s => s.ToString()).ToArray();
    var statusData = allStatuses.Select(s => statusGroups.ContainsKey(s) ? statusGroups[s] : 0).ToArray();

    var statusColors = new[]
    {
        "#f39c12", // New
        "#3498db", // Open
        "#2980b9", // Progress
        "#27ae60", // Resolved
        "#2ecc71", // Done
        "#95a5a6", // Canceled
        "#e74c3c"  // Reopened
    };

   
    var priorityGroups = Model
        .GroupBy(t => t.Priority)
        .ToDictionary(g => g.Key, g => g.Count());

    var allPriorities = Enum.GetValues(typeof(TicketPriority)).Cast<TicketPriority>().ToList();
    var priorityLabels = allPriorities.Select(p => p.ToString()).ToArray();
    var priorityData = allPriorities.Select(p => priorityGroups.ContainsKey(p) ? priorityGroups[p] : 0).ToArray();

    var priorityColors = new[]
    {
        "#95a5a6", // None
        "#2ecc71", // Low
        "#3498db", // Medium
        "#f39c12", // High
        "#e74c3c"  // Critical
    };

   
    Func<Status, string> statusBadgeClass = status => status switch
    {
        Status.New => "bg-warning text-dark",
        Status.Open => "bg-primary text-white",
        Status.Progress => "bg-info text-white",
        Status.Resolved => "bg-success text-white",
        Status.Done => "bg-secondary text-white",
        Status.Canceled => "bg-danger text-white",
        Status.Reopened => "bg-warning text-dark",
        _ => "bg-dark text-white"
    };

  
    Func<TicketPriority, string> priorityBadgeClass = priority => priority switch
    {
        TicketPriority.Low => "bg-secondary text-white",
        TicketPriority.Medium => "bg-primary text-white",
        TicketPriority.High => "bg-warning text-dark",
        TicketPriority.Critical => "bg-danger text-white",
        _ => "bg-dark text-white"
    };
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Coordinator Desk</div>
        <h1 class="section-title">Review the full ticket pipeline and rebalance work when needed.</h1>
        <p class="section-copy">
            This screen combines ticket inventory, quick actions, and summary charts so coordinators can assign responsibility and clear stalled work without jumping across multiple pages.
        </p>
    </section>

    <div class="dashboard-grid">
        <section class="dashboard-panel">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                <div>
                    <h2 class="mb-1">@ViewData["Title"]</h2>
                    <p class="text-muted mb-0">Live view of status, priority, ownership, and ticket lifecycle.</p>
                </div>
            </div>
            <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-dark text-white">
                    <tr>
                        <th>#</th>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Category</th>
                        <th>SubCategory</th>
                        <th>Author Name</th>
                        <th>Assigned To</th>
                        <th>Created At</th>
                        <th>Closed At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="table-light">
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td><strong>@ticket.Id</strong></td>
                            <td class="text-truncate truncate-200" title="@ticket.Title">@ticket.Title</td>
                            <td><span class="badge @statusBadgeClass(ticket.Status)">@ticket.Status</span></td>
                            <td><span class="badge @priorityBadgeClass(ticket.Priority)">@ticket.Priority</span></td>
                            <td>@ticket.Category?.Name</td>
                            <td>@ticket.TicketSubCategory?.Name</td>
                            <td>@ticket.Author?.UserName</td>
                            <td>@ticket.AssignedUser</td>
                            <td>@ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(ticket.ClosedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-outline-secondary dropdown-toggle" type="button"
                                            id="ticketActionsDropdown-@ticket.Id"
                                            data-bs-toggle="dropdown" aria-expanded="false">
                                        Actions
                                    </button>
                                    <ul class="dropdown-menu" aria-labelledby="ticketActionsDropdown-@ticket.Id">
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="TicketAssignment"
                                               asp-action="InfoAboutTicket"
                                               asp-route-id="@ticket.Id">
                                                Information
                                            </a>
                                        </li>
                                        @if (ticket.Status != Status.Canceled && ticket.Status != Status.Done)
                                        {
                                            <li>
                                                <a class="dropdown-item"
                                                   asp-controller="TicketAssignment"
                                                   asp-action="AssignTechnician"
                                                   asp-route-id="@ticket.Id">
                                                    Manage
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item"
                                                   asp-controller="TicketAssignment"
                                                   asp-action="AssignPriority"
                                                   asp-route-id="@ticket.Id">
                                                    Manage priority
                                                </a>
                                            </li>
                                            <li>
                                                <button class="dropdown-item text-danger" type="button"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#cancelTicketModal-@ticket.Id">
                                                    Cancel Ticket
                                                </button>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>

                      
                        <div class="modal fade" id="cancelTicketModal-@ticket.Id" tabindex="-1"
                             aria-labelledby="cancelTicketModalLabel-@ticket.Id"
                             aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="cancelTicketModalLabel-@ticket.Id">Cancel Ticket</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <form method="post"
                                              asp-controller="TicketAssignment"
                                              asp-action="CancelTicket">
                                            <input type="hidden" name="id" value="@ticket.Id" />
                                            <div class="mb-3">
                                                <label for="reason-@ticket.Id" class="form-label">Reason for Cancellation:</label>
                                                <textarea class="form-control" id="reason-@ticket.Id" name="reason" rows="3"
                                                          placeholder="Please provide a reason for canceling the ticket"
                                                          required></textarea>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-outline-secondary"
                                                        data-bs-dismiss="modal">
                                                    Cancel
                                                </button>
                                                <button type="submit" class="btn btn-outline-danger">Confirm Cancel</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
        </section>

        <aside class="dashboard-sidebar">
            <div class="chart-card text-center">
                <h5 class="mb-3">Status Distribution</h5>
                <canvas id="statusChart" width="300" height="300"></canvas>
            </div>
            <div class="chart-card text-center">
                <h5 class="mb-3">Priority Distribution</h5>
                <canvas id="priorityChart" width="300" height="300"></canvas>
            </div>
            <div class="chart-card">
                <h5 class="mb-3">Coordinator Actions</h5>
                <div class="action-grid">
                    <form asp-action="AssignTickets" method="post" class="d-grid">
                        <button type="submit" class="btn btn-outline-success w-100">Assign Tickets</button>
                    </form>

                    <form asp-action="ResetTickets" method="post" class="d-grid">
                        <button type="submit" class="btn btn-outline-danger w-100">Reset Tickets</button>
                    </form>

                    <div>
                        <button class="btn btn-outline-primary w-100" type="button" id="filterBtn"
                        data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-funnel"></i> Filters
                        </button>
                        <div class="dropdown-menu dropdown-panel-md p-3">
                            <form method="get" class="row g-2">
                                <div class="col-12">
                                    <label class="form-label small mb-1">Category</label>
                                    <select name="CategoryId" class="form-select form-select-sm">
                                        <option value="">All</option>
                                        @foreach (var category in (ViewBag.Categories as List<SelectListItem>)!)
                                        {
                                            <option value="@category.Value">@category.Text</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-12">
                                    <label class="form-label small mb-1">Priority</label>
                                    <select name="Priority" class="form-select form-select-sm">
                                        <option value="">All</option>
                                        @foreach (var p in Enum.GetValues(typeof(TicketPriority)))
                                        {
                                            <option value="@p">@p</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-12">
                                    <label class="form-label small mb-1">Status</label>
                                    <select name="Status" class="form-select form-select-sm">
                                        <option value="">All</option>
                                        @foreach (var s in Enum.GetValues(typeof(Status)))
                                        {
                                            <option value="@s">@s</option>
                                        }
                                    </select>
                                </div>

                                <div class="col-12 d-grid">
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-search"></i> Apply
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  
    function createPieChart(ctx, labels, data, colors) {
        return new Chart(ctx, {
            type: 'pie',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: colors,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: false,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 14 } } },
                    tooltip: { enabled: true }
                }
            }
        });
    }

    // Status chart data
    const statusLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statusLabels));
    const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statusData));
    const statusColors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(statusColors));

    // Priority chart data
    const priorityLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(priorityLabels));
    const priorityData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(priorityData));
    const priorityColors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(priorityColors));

    // Create charts
    createPieChart(document.getElementById('statusChart').getContext('2d'), statusLabels, statusData, statusColors);
    createPieChart(document.getElementById('priorityChart').getContext('2d'), priorityLabels, priorityData, priorityColors);
</script>
