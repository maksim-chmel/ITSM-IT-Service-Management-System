@model IEnumerable<ITSM.Models.TicketCategory>
@{
    ViewData["Title"] = "Deleted Categories and Subcategories";
}

<div class="d-grid gap-4">
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Restore deleted categories and nested subcategories.</p>
            </div>
        </div>

        <div class="page-actions mb-3">
            <form asp-action="RestoreCategories" method="post" id="restoreCategoriesForm">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore Selected Categories
                </button>
            </form>

            <form asp-action="RestoreSubCategories" method="post" id="restoreSubForm">
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-counterclockwise"></i> Restore Selected Subcategories
                </button>
            </form>
        </div>

        <div class="split-grid">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-center">
                    <thead class="table-dark text-white">
                        <tr>
                            <th><input type="checkbox" id="selectAllCategories" /></th>
                            <th>Name</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody class="table-light">
                        @foreach (var category in Model.Where(c => c.IsDeleted))
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" name="selectedCategoryIds" value="@category.Id" form="restoreCategoriesForm" class="form-check-input" />
                                </td>
                                <td><strong>@category.Name</strong></td>
                                <td>Category</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle text-center">
                    <thead class="table-dark text-white">
                        <tr>
                            <th><input type="checkbox" id="selectAllSubCategories" /></th>
                            <th>Name</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody class="table-light">
                        @foreach (var category in Model)
                        {
                            foreach (var sub in category.SubCategories.Where(s => s.IsDeleted))
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" name="selectedSubCategoryIds" value="@sub.Id" form="restoreSubForm" class="form-check-input" />
                                    </td>
                                    <td class="ps-4">@sub.Name</td>
                                    <td>Subcategory</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
       
        document.getElementById("selectAllCategories").addEventListener("change", function () {
            const checkboxes = document.querySelectorAll('input[name="selectedCategoryIds"]');
            checkboxes.forEach(cb => cb.checked = this.checked);
        });

       
        document.getElementById("selectAllSubCategories").addEventListener("change", function () {
            const checkboxes = document.querySelectorAll('input[name="selectedSubCategoryIds"]');
            checkboxes.forEach(cb => cb.checked = this.checked);
        });
    </script>
}
