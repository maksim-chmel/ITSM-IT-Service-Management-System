@using ITSM.Enums
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model ITSM.ViewModels.TicketDetailsViewModel

@if (TempData["TicketClosed"] != null)
{
    <div class="alert alert-success" role="alert">
        Заявка успешно закрыта.
    </div>
}
<h1>@Model.Ticket.Title</h1>

<table class="table">
    <tr>
        <th>Номер:</th>
        <td>@Model.Ticket.Id</td>
    </tr>
    <tr>
        <th>Название:</th>
        <td>@Model.Ticket.Title</td>
    </tr>
    <tr>
        <th>Описание:</th>
        <td>@Model.Ticket.Description</td>
    </tr>
    <tr>
        <th>Дата создания:</th>
        <td>@Model.Ticket.CreatedAt</td>
    </tr>
    <tr>
        <th>Автор:</th>
        <td>@Model.Ticket.Author?.UserName</td>
    </tr>
    <tr>
        <th>Назначено:</th>
        <td>@Model.Ticket.AssignedUser</td>
    </tr>
    <tr>
        <th>FixDescription:</th>
        <td>@Model.Ticket.FixDescription</td>
    </tr>
    <tr>
        <th>Статус:</th>
        <td>@Model.Ticket.Status</td>
    </tr>
</table>

<h3>Заметки</h3>
<table class="table">
    <thead>
    <tr>
        <th>Дата</th>
        <th>Заметка</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var note in Model.TicketHistory)
    {
        <tr>
            <td>@note.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
            <td>@note.AdminComment</td>
        </tr>
    }
    </tbody>
</table>

@switch (Model.Ticket.Status)
{
    case TicketStatus.Resolved:
        <form asp-controller="TicketAssignment" asp-action="CloseTicket" method="post">
            <input type="hidden" name="id" value="@Model.Ticket.Id"/>
            <button type="submit" class="btn btn-success">Закрыть</button>
        </form>
        break;
    case TicketStatus.Closed:
        <form asp-controller="TicketAssignment" asp-action="ReOpenTicket" method="post">
            <input type="hidden" name="id" value="@Model.Ticket.Id"/>
            <button type="submit" class="btn btn-success">Открыть снова</button>
        </form>
        break;
}
<a asp-controller="TicketAssignment" asp-action="ReviewTickets" class="btn btn-secondary">Назад</a>
