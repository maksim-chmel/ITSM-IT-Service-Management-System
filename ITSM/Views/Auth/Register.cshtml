@model ITSM.ViewModels.Authorization.RegisterViewModel
<form asp-action="Register" method="post" class="p-4 rounded shadow-sm bg-light">
    <h2 class="text-center mb-4">Регистрация</h2>

    <div class="form-floating mb-3">
        <input asp-for="UserName" type="text" class="form-control" id="floatingUserName" placeholder="Имя пользователя"
               required>
        <label for="floatingUserName">Имя пользователя</label>
        <span asp-validation-for="UserName" class="invalid-feedback"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Email" type="email" class="form-control" id="floatingEmail" placeholder="name@example.com"
               required>
        <label for="floatingEmail">Email</label>
        <span asp-validation-for="Email" class="invalid-feedback"></span>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Пароль"
               required>
        <label for="floatingPassword">Пароль</label>
        <span asp-validation-for="Password" class="invalid-feedback"></span>
        <div class="form-text">
            Пароль должен содержать 8-20 символов, буквы и цифры, без пробелов и спецсимволов.
        </div>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="ConfirmPassword" type="password" class="form-control" id="floatingConfirmPassword"
               placeholder="Повторите пароль" required>
        <label for="floatingConfirmPassword">Подтверждение пароля</label>
        <span asp-validation-for="ConfirmPassword" class="invalid-feedback"></span>
    </div>

    <div class="form-check mb-3">
        <input type="checkbox" class="form-check-input" id="showPassword">
        <label class="form-check-label" for="showPassword">Показать пароль</label>
    </div>

    <button type="submit" class="btn  btn-outline-primary w-100">Зарегистрироваться
        <i class="bi bi-box-arrow-in-right"></i></button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const password = document.getElementById("floatingPassword");
        const confirmPassword = document.getElementById("floatingConfirmPassword");
        const showPasswordCheckbox = document.getElementById("showPassword");
        const inputs = document.querySelectorAll(".form-control");


        inputs.forEach(input => {
            input.addEventListener("input", function () {
                this.classList.toggle("is-invalid", !this.checkValidity());
                this.classList.toggle("is-valid", this.checkValidity());
            });
        });


        const checkPasswords = () => {
            const passwordsMatch = password.value === confirmPassword.value;
            confirmPassword.classList.toggle("is-invalid", password.value && !passwordsMatch);
            confirmPassword.classList.toggle("is-valid", password.value && passwordsMatch);
        };

        password.addEventListener("input", checkPasswords);
        confirmPassword.addEventListener("input", checkPasswords);


        showPasswordCheckbox.addEventListener("change", function () {
            const type = this.checked ? "text" : "password";
            password.type = type;
            confirmPassword.type = type;
        });
    });
</script>
