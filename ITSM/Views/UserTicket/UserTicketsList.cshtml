@using ITSM.Enums
@model IEnumerable<ITSM.Models.Ticket>
@{
    ViewData["Title"] = "All Tickets";
}
<h2 class="text-center mb-4">@ViewData["Title"]</h2>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover table-bordered align-middle text-center">
        <thead class="table-dark text-white">
        <tr>
            <th>#</th>
            <th>Title</th>
            <th>Category</th>
            <th>Description</th>
            <th>Status</th>
            <th>Created At</th>
        </tr>
        </thead>
        <tbody class="table-light">
        @foreach (var ticket in Model)
        {
            <tr>
                <td><strong>@ticket.Id</strong></td>
                <td>@ticket.Title</td>
                <td>@ticket.Category?.Name</td>
                <td class="text-truncate" style="max-width: 250px;" title="@ticket.Description">
                    @ticket.Description
                </td>
                <td>
                    <span class="badge 
                        @(ticket.Status == TicketStatus.Open ? "bg-primary text-white" :
                        ticket.Status == TicketStatus.Progress ? "bg-info text-white" :
                        ticket.Status == TicketStatus.Resolved ? "bg-success text-white" :
                        ticket.Status == TicketStatus.Canceled ? "bg-danger text-white" :
                        ticket.Status == TicketStatus.Done ? "bg-secondary text-white" : "bg-dark")">
                        @ticket.Status
                    </span>
                </td>
                <td>@ticket.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
