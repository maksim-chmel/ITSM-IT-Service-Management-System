@model IEnumerable<ITSM.Models.Discussion>

@{
    ViewData["Title"] = "Resolved Discussions";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Team Discussions</div>
        <h1 class="section-title">Resolved threads kept for audit and later reference.</h1>
        <p class="section-copy">Resolved does not mean archived. Use Archive when you want to move a thread into the archive section.</p>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Browse resolved threads.</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-controller="Discussion" asp-action="ListOfDiscussions" class="btn btn-outline-secondary btn-sm">
                    Back to Open
                </a>
            </div>
        </div>

        <form method="get" class="compact-search mb-4">
            <input type="text" name="search" class="form-control" placeholder="Search by title..." value="@Context.Request.Query["search"]" />
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
        </form>

        @if (!Model.Any())
        {
            <p class="text-center mb-0">No resolved discussion topics.</p>
        }
        else
        {
            <div class="discussion-grid">
                @foreach (var thread in Model)
                {
                    <article class="tile-card">
                        <div class="tile-card__icon"><i class="bi bi-chat-check"></i></div>
                        <h5 class="card-title text-truncate">@thread.Title</h5>
                        <p class="card-text">
                            <strong>Author:</strong> @thread.Author?.UserName <br />
                            <strong>Closed:</strong> @(thread.ClosedAt?.ToLocalTime().ToString("g") ?? "-")
                        </p>
                        <a asp-action="ViewDiscussion" asp-route-id="@thread.Id" class="btn btn-outline-primary btn-sm w-100">
                            <i class="bi bi-chat-text"></i> View
                        </a>
                    </article>
                }
            </div>
        }
    </section>
</div>

