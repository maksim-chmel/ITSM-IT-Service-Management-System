@model ITSM.Models.Discussion
<div class="d-grid gap-4">
    <section class="surface-card">
        <div class="page-header">
            <div>
                <h3 class="mb-1">@Model.Title</h3>
                <p class="text-muted mb-0">@Model.Description</p>
            </div>
            <div class="d-flex gap-2">
                @if(Model.TicketId.HasValue)
                {
                    <a asp-controller="TechnicianTicket" asp-action="ShowDetailsAboutTicket" asp-route-id="@Model.TicketId" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-ticket-perforated"></i> View Linked Ticket #@Model.TicketId
                    </a>
                }
                
                @using Microsoft.AspNetCore.Identity
                @using ITSM.Models
                @using System.Security.Claims
                
                @if (Model.AuthorId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                {
                    <form asp-action="ResolveDiscussion" asp-route-id="@Model.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-check-circle"></i> Resolve
                        </button>
                    </form>
                    <form asp-action="ArchiveDiscussion" asp-route-id="@Model.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-archive"></i> Archive
                        </button>
                    </form>
                }
                <a asp-action="ListOfDiscussions" class="btn btn-outline-secondary btn-sm">Close</a>
            </div>
        </div>

        <p class="small text-muted mb-3">
            <strong>Author:</strong> @Model.Author.UserName |
            <strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("g")
        </p>

        <div class="chat-box mb-3">
            @if (Model.Messages != null && Model.Messages.Any())
            {
                @foreach (var message in Model.Messages.OrderBy(m => m.CreatedAt))
                {
                    <div class="msg-row @(message.AuthorId == Model.AuthorId ? "me" : "other")">
                        <div class="bubble">
                            <div class="msg-header">
                                <span>@message.Author?.UserName</span>
                                <span>@message.CreatedAt.ToLocalTime().ToString("g")</span>
                            </div>
                            <div class="msg-text">@message.Content</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-muted text-center small py-2">No messages yet.</div>
            }
        </div>

        <form method="post" asp-action="AddMessage" asp-route-id="@Model.Id" class="input-area d-flex gap-2">
            <textarea name="MessageContent" class="form-control form-control-sm" placeholder="Type your message..." rows="1" required maxlength="1000"></textarea>
            <button type="submit" class="btn btn-outline-primary btn-sm">Send</button>
        </form>
    </section>
</div>
