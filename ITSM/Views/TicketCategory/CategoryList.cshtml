@model IEnumerable<ITSM.Models.TicketCategory>
@{
    ViewData["Title"] = "Category Management";
}

<div class="d-grid gap-4">
    <section class="page-hero">
        <div class="eyebrow">Taxonomy</div>
        <h1 class="section-title">Manage ticket categories and subcategories in one place.</h1>
        <p class="section-copy">Organize your service structure by grouping related subcategories under main categories.</p>
    </section>

    <section class="surface-card">
        <div class="page-header">
            <div>
                <h2>@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Expand categories to manage their subcategories or add new ones.</p>
            </div>
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
                <i class="bi bi-plus-circle"></i> New Category
            </button>
        </div>

        <div class="stack-grid">
            @foreach (var category in Model)
            {
                <div class="info-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-3">
                            <h4 class="mb-0">@category.Name</h4>
                            <span class="badge bg-secondary">@category.SubCategories.Count Subcategories</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@category.Id">
                                <i class="bi bi-chevron-down"></i> Manage Subcategories
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    data-bs-toggle="modal" data-bs-target="#archiveCategoryModal"
                                    data-action="@Url.Action("DeleteCategory", "TicketCategory", new { id = category.Id })"
                                    data-message="Archive category «@category.Name» and all its subcategories?">
                                <i class="bi bi-archive"></i> Archive
                            </button>
                        </div>
                    </div>

                    <div class="collapse" id="collapse-@category.Id">
                        <div class="ps-4 border-start mt-3">
                            <ul class="list-group list-group-flush mb-3">
                                @if (category.SubCategories.Any())
                                {
                                    @foreach (var sub in category.SubCategories)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                            <span>@sub.Name</span>
                                            <button type="button" class="btn btn-link text-danger p-0"
                                                    data-bs-toggle="modal" data-bs-target="#archiveCategoryModal"
                                                    data-action="@Url.Action("DeleteSubCategory", "TicketCategory", new { subCategoryId = sub.Id })"
                                                    data-message="Archive subcategory «@sub.Name»?">
                                                <i class="bi bi-archive"></i> Archive
                                            </button>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="list-group-item bg-transparent text-muted small">No subcategories yet.</li>
                                }
                            </ul>

                            <form asp-action="AddSubCategory" method="post" class="d-flex gap-2">
                                <input type="hidden" name="CategoryId" value="@category.Id" />
                                <input type="text" name="Name" class="form-control form-control-sm" placeholder="New subcategory name" required />
                                <button type="submit" class="btn btn-sm btn-outline-success">Add</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

<!-- Shared Archive Confirmation Modal -->
<form id="archiveCategoryForm" method="post">
    @Html.AntiForgeryToken()
</form>
<div class="modal fade" id="archiveCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Archive</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="archiveCategoryMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="archiveCategoryConfirm">Archive</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("archiveCategoryModal").addEventListener("show.bs.modal", function (e) {
            const btn = e.relatedTarget;
            document.getElementById("archiveCategoryMessage").textContent = btn.dataset.message;
            document.getElementById("archiveCategoryForm").action = btn.dataset.action;
        });
        document.getElementById("archiveCategoryConfirm").addEventListener("click", function () {
            document.getElementById("archiveCategoryForm").submit();
        });
    </script>
}

<!-- Create Category Modal -->
<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateCategory" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="categoryName" class="form-label">Category Name</label>
                        <input type="text" id="categoryName" name="name" class="form-control" placeholder="e.g. Hardware, Software" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-outline-primary">Create Category</button>
                </div>
            </form>
        </div>
    </div>
</div>
